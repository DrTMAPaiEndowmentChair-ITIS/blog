---
import FormattedDate from '@/components/widgets/FormattedDate.astro'
import type { PostListProps } from '@/types'
import { themeConfig } from '@/config'
import { POST_CATEGORIES } from '@/data/taxonomy'

const { posts } = Astro.props as PostListProps

const categoryGroups = POST_CATEGORIES.map((category) => ({
  category,
  posts: posts.filter((post) => post.data.category === category)
})).filter((group) => group.posts.length > 0)
---

<section class="post-directory" data-post-search>
  <form class="search" role="search" aria-label="Search posts">
    <label for="post-query">Search</label>
    <div class="search-control">
      <input
        id="post-query"
        name="q"
        type="search"
        placeholder="Title, topic, or category"
        autocomplete="off"
        spellcheck="false"
      />
      <button type="reset" disabled>Clear</button>
    </div>
  </form>

  <div class="search-summary">
    <span class="result-count" role="status" aria-live="polite">
      {posts.length} posts across {categoryGroups.length} categories
    </span>
  </div>

  <div class="category-groups">
    {
      categoryGroups.map(({ category, posts: categoryPosts }) => (
        <section class="category-group" data-category-group>
          <h2>
            <span>{category}</span>
            <span
              class="category-count"
              data-category-count
              aria-label={`${categoryPosts.length} posts`}
            >
              {categoryPosts.length}
            </span>
          </h2>
          <ul>
            {categoryPosts.map((post) => (
              <li
                data-post
                data-search={[
                  post.data.title,
                  post.data.description,
                  post.data.category,
                  ...post.data.topics
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/${post.id}/`}>
                  <div class={`post-item ${!themeConfig.date.dateOnRight ? 'date-left' : ''}`}>
                    {!themeConfig.date.dateOnRight && (
                      <p class="date font-features">
                        <FormattedDate date={post.data.pubDate} context="list" />
                      </p>
                    )}
                    <p class="title">{post.data.title}</p>
                    {themeConfig.date.dateOnRight && (
                      <div
                        class={
                          themeConfig.general.postListDottedDivider ? 'dotted-divider' : 'divider'
                        }
                      />
                    )}
                    {themeConfig.date.dateOnRight && (
                      <p class="date font-features">
                        <FormattedDate date={post.data.pubDate} context="list" />
                      </p>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <div class="empty-state" hidden>No posts match this search.</div>
</section>
<div class="placeholder"></div>

<script>
  let readActiveSearch: (() => void) | undefined

  const normalizeSearch = (value: string) =>
    value
      .normalize('NFKD')
      .replace(/\p{Diacritic}/gu, '')
      .trim()
      .toLocaleLowerCase()

  const initializePostSearch = () => {
    readActiveSearch = undefined
    const searchDirectories = document.querySelectorAll<HTMLElement>('[data-post-search]')

    for (const directory of searchDirectories) {
      const form = directory.querySelector<HTMLFormElement>('.search')
      const queryInput = form?.elements.namedItem('q')
      const clearButton = form?.querySelector<HTMLButtonElement>('button[type="reset"]')
      const resultCount = directory.querySelector<HTMLElement>('.result-count')
      const emptyState = directory.querySelector<HTMLElement>('.empty-state')
      const categoryGroups = [...directory.querySelectorAll<HTMLElement>('[data-category-group]')]
      const postItems = [...directory.querySelectorAll<HTMLElement>('[data-post]')]

      if (
        !form ||
        !(queryInput instanceof HTMLInputElement) ||
        !clearButton ||
        !resultCount ||
        !emptyState
      ) {
        continue
      }

      const applySearch = (updateUrl: boolean) => {
        const query = normalizeSearch(queryInput.value)
        let visibleCount = 0
        let visibleCategoryCount = 0

        for (const item of postItems) {
          const isVisible = !query || normalizeSearch(item.dataset.search ?? '').includes(query)

          item.hidden = !isVisible
          if (isVisible) visibleCount += 1
        }

        for (const group of categoryGroups) {
          const visiblePosts = [...group.querySelectorAll<HTMLElement>('[data-post]')].filter(
            (post) => !post.hidden
          )
          const count = group.querySelector<HTMLElement>('[data-category-count]')

          group.hidden = visiblePosts.length === 0
          if (visiblePosts.length > 0) visibleCategoryCount += 1
          if (count) {
            count.textContent = `${visiblePosts.length}`
            count.setAttribute(
              'aria-label',
              `${visiblePosts.length} ${visiblePosts.length === 1 ? 'post' : 'posts'}`
            )
          }
        }

        resultCount.textContent = `${visibleCount} ${
          visibleCount === 1 ? 'post' : 'posts'
        } across ${visibleCategoryCount} ${visibleCategoryCount === 1 ? 'category' : 'categories'}`
        emptyState.hidden = visibleCount !== 0
        clearButton.disabled = queryInput.value.length === 0

        if (updateUrl) {
          const url = new URL(window.location.href)
          if (queryInput.value.trim()) url.searchParams.set('q', queryInput.value.trim())
          else url.searchParams.delete('q')

          url.searchParams.delete('category')
          url.searchParams.delete('topic')
          window.history.replaceState(null, '', url)
        }
      }

      const readUrl = () => {
        const params = new URLSearchParams(window.location.search)
        const query = params.get('q') ?? params.get('category') ?? params.get('topic') ?? ''

        queryInput.value = query
        applySearch(false)
      }

      form.addEventListener('input', () => applySearch(true))
      form.addEventListener('submit', (event) => {
        event.preventDefault()
        applySearch(true)
      })
      form.addEventListener('reset', () => {
        window.setTimeout(() => {
          applySearch(true)
          queryInput.focus()
        })
      })

      readActiveSearch = readUrl
      readUrl()
    }
  }

  window.addEventListener('popstate', () => readActiveSearch?.())
  document.addEventListener('astro:page-load', initializePostSearch)
</script>

<style>
  .search {
    display: grid;
    gap: 0.25rem;
    margin: 1.75rem 0 0;
  }

  .search label {
    color: var(--text-secondary);
    font-size: var(--font-size-s);
  }

  .search-control {
    display: flex;
    gap: 0.5rem;
  }

  .search input,
  .search button {
    height: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    background: var(--bg);
    color: var(--text-primary);
    font: inherit;
    font-size: var(--font-size-s);
  }

  .search input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0 0.75rem;
  }

  .search input::placeholder {
    color: var(--text-tertiary);
  }

  .search button {
    flex: 0 0 auto;
    padding: 0 0.75rem;
    cursor: pointer;
  }

  .search button:disabled {
    color: var(--text-tertiary);
    cursor: default;
  }

  .search input:focus-visible,
  .search button:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }

  .search-summary {
    min-height: 1.25rem;
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-size: var(--font-size-s);
  }

  .category-groups {
    margin-top: 1.75rem;
  }

  .category-group + .category-group {
    margin-top: 2rem;
  }

  .category-group h2 {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.375rem;
    margin: 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    font-size: var(--font-size-s);
    font-weight: var(--font-weight-bold);
  }

  .category-count {
    color: var(--text-secondary);
    font-weight: var(--font-weight-regular);
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  a {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover a {
      opacity: 0.4;
    }

    ul:hover a:hover {
      opacity: 1;
    }

    ul:hover a:hover .divider {
      background-color: var(--text-tertiary);
      opacity: 0.75;
    }
    ul:hover a:hover .dotted-divider {
      color: var(--text-secondary);
    }
    ul:hover a:hover .date {
      color: var(--text-secondary);
      opacity: 1;
    }
  }

  .post-item {
    height: 2.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .post-item.date-left {
    justify-content: flex-start;
  }

  .post-item.date-left .title {
    flex: 1 1 auto;
    min-width: 0;
  }

  .post-item.date-left .date {
    margin-right: 0.75rem;
  }

  .title {
    margin: 0;
    flex-shrink: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .date {
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.75;
    letter-spacing: var(--spacing-s);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .divider {
    flex: 1 1 auto;
    min-width: 3rem;
    margin: 0 0.25rem;
    height: 0.5px;
    background-color: var(--border);
  }

  .dotted-divider {
    flex: 1 1 3rem;
    min-width: 3rem;
    max-width: 100%;
    text-align: end;
    letter-spacing: 5px;
    height: 1.675rem;
    overflow: hidden;
    color: var(--text-tertiary);
    opacity: 0.75;
  }

  .dotted-divider::after {
    content: '·····························································································································································';
    pointer-events: none;
  }

  .empty-state {
    padding: 1.25rem 0;
    color: var(--text-secondary);
  }

  .placeholder {
    height: 3rem;
  }
</style>
