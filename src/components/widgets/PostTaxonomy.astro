---
interface Props {
  category: string
  topics?: string[]
}

const { category, topics = [] } = Astro.props
---

<nav class="taxonomy" aria-label="Post taxonomy">
  <a class="category" href={`/?category=${encodeURIComponent(category)}`}>{category}</a>
  {
    topics.length > 0 && (
      <>
        <span class="separator" aria-hidden="true">
          ·
        </span>
        <span class="topics">
          {topics.map((topic) => (
            <a href={`/?topic=${encodeURIComponent(topic)}`}>{topic}</a>
          ))}
        </span>
      </>
    )
  }
</nav>

<style>
  .taxonomy {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 0.5rem;
    margin-top: 0.375rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .taxonomy a {
    color: inherit;
    font-size: var(--font-size-s);
    text-decoration: none;
  }

  .taxonomy a:hover {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .taxonomy a:focus-visible {
    border-radius: 0.125rem;
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }

  .category {
    font-weight: var(--font-weight-bold);
  }

  .separator {
    color: var(--text-tertiary);
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.625rem;
  }
</style>
