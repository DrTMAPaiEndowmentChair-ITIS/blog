---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '@/components/widgets/FormattedDate.astro'
import { POST_CATEGORIES } from '@/data/taxonomy'

interface Props {
  posts: CollectionEntry<'posts'>[]
}

const { posts } = Astro.props as Props
const orderedPosts = [...posts].sort((a, b) => {
  const featuredDifference = Number(b.data.featured) - Number(a.data.featured)
  return featuredDifference || b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
})
const latestDate = orderedPosts.reduce(
  (latest, post) => (post.data.pubDate > latest ? post.data.pubDate : latest),
  orderedPosts[0]?.data.pubDate ?? new Date()
)
const categoryCounts = Object.fromEntries(
  POST_CATEGORIES.map((category) => [
    category,
    orderedPosts.filter((post) => post.data.category === category).length
  ])
)
---

<main class="front-page" data-post-explorer data-filtered="false">
  <header class="masthead">
    <div class="masthead__eyebrow">
      <span>Technical Review</span>
      <span class="masthead__rule" aria-hidden="true"></span>
      <span>
        Updated <FormattedDate date={latestDate} context="list" />
      </span>
    </div>
    <div class="masthead__body">
      <h1>Ideas and systems <em>behind modern AI.</em></h1>
      <p>
        Rigorous, practical guides to the models, infrastructure, and hardware shaping intelligent
        systems—from first principles to production.
      </p>
    </div>
    <div class="masthead__index" aria-label="Publication overview">
      <span><strong>{orderedPosts.length}</strong> field guides</span>
      <span><strong>{POST_CATEGORIES.length}</strong> desks</span>
      <a href="#stories">Browse the edition <span aria-hidden="true">↓</span></a>
    </div>
  </header>

  <section class="explorer" aria-labelledby="browse-heading">
    <div class="explorer__heading">
      <div>
        <p class="section-label">The archive</p>
        <h2 id="browse-heading">Find your next deep dive</h2>
      </div>
      <label class="search">
        <span class="sr-only">Search articles</span>
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="6.5"></circle>
          <path d="m16 16 4 4"></path>
        </svg>
        <input
          type="search"
          placeholder="Search topics, tools, or systems"
          autocomplete="off"
          data-search-input
        />
        <button type="button" class="search__clear" data-clear-search aria-label="Clear search">
          Clear
        </button>
      </label>
    </div>

    <div class="filters" aria-label="Filter articles by desk">
      <button type="button" class="filter is-active" data-category="All" aria-pressed="true">
        <span>All desks</span>
        <span class="filter__count">{orderedPosts.length}</span>
      </button>
      {
        POST_CATEGORIES.map((category) => (
          <button type="button" class="filter" data-category={category} aria-pressed="false">
            <span>{category}</span>
            <span class="filter__count">{categoryCounts[category]}</span>
          </button>
        ))
      }
    </div>

    <div class="results-bar" aria-live="polite">
      <p data-results-count>{orderedPosts.length} articles</p>
      <button type="button" data-reset-filters>Reset filters</button>
    </div>

    <div class="story-grid" id="stories">
      {
        orderedPosts.map((post, index) => (
          <article
            class:list={[
              'story',
              index === 0 && 'story--lead',
              (index === 1 || index === 2) && 'story--secondary'
            ]}
            data-story
            data-category={post.data.category}
            data-search={[
              post.data.title,
              post.data.description,
              post.data.category,
              ...post.data.topics
            ]
              .join(' ')
              .toLocaleLowerCase()}
          >
            <a href={`/${post.id}/`}>
              <div class="story__topline">
                <span class="story__category">{post.data.category}</span>
                <span class="story__number">{String(index + 1).padStart(2, '0')}</span>
              </div>
              <div class="story__body">
                {index === 0 && <p class="story__flag">Lead story</p>}
                <h3>{post.data.title}</h3>
                <p class="story__description">{post.data.description}</p>
              </div>
              <div class="story__footer">
                <span class="story__date">
                  <FormattedDate date={post.data.pubDate} context="list" />
                </span>
                <ul aria-label="Topics">
                  {post.data.topics.slice(0, 3).map((topic) => (
                    <li>{topic}</li>
                  ))}
                </ul>
                <span class="story__arrow" aria-hidden="true">
                  ↗
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <div class="empty-state" data-empty-state hidden>
      <p class="section-label">No matches</p>
      <h3>Try a broader search.</h3>
      <p>Clear the search or choose another desk to see more field guides.</p>
      <button type="button" data-empty-reset>Show all articles</button>
    </div>
  </section>
</main>

<script>
  function initialisePostExplorer() {
    const root = document.querySelector<HTMLElement>('[data-post-explorer]')
    if (!root || root.dataset.initialised === 'true') return

    root.dataset.initialised = 'true'
    const stories = Array.from(root.querySelectorAll<HTMLElement>('[data-story]'))
    const categoryButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-category]'))
    const searchInput = root.querySelector<HTMLInputElement>('[data-search-input]')
    const clearSearchButton = root.querySelector<HTMLButtonElement>('[data-clear-search]')
    const resultsCount = root.querySelector<HTMLElement>('[data-results-count]')
    const resetButtons = Array.from(
      root.querySelectorAll<HTMLButtonElement>('[data-reset-filters], [data-empty-reset]')
    )
    const emptyState = root.querySelector<HTMLElement>('[data-empty-state]')

    if (!searchInput || !clearSearchButton || !resultsCount || !emptyState) return

    const url = new URL(window.location.href)
    let activeCategory = url.searchParams.get('category') || 'All'
    if (!categoryButtons.some((button) => button.dataset.category === activeCategory)) {
      activeCategory = 'All'
    }
    searchInput.value = url.searchParams.get('q') || ''

    function applyFilters(updateUrl = true) {
      const query = searchInput?.value.trim().toLocaleLowerCase() || ''
      let visibleCount = 0

      stories.forEach((story) => {
        const categoryMatches =
          activeCategory === 'All' || story.dataset.category === activeCategory
        const searchMatches = !query || story.dataset.search?.includes(query)
        const visible = categoryMatches && searchMatches
        story.hidden = !visible
        if (visible) visibleCount += 1
      })

      categoryButtons.forEach((button) => {
        const isActive = button.dataset.category === activeCategory
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', String(isActive))
      })

      root.dataset.filtered = String(activeCategory !== 'All' || Boolean(query))
      clearSearchButton.hidden = !query
      emptyState.hidden = visibleCount !== 0
      resultsCount.textContent =
        visibleCount === stories.length && activeCategory === 'All' && !query
          ? `${stories.length} articles`
          : `Showing ${visibleCount} of ${stories.length} articles`

      if (!updateUrl) return
      const nextUrl = new URL(window.location.href)
      if (activeCategory === 'All') nextUrl.searchParams.delete('category')
      else nextUrl.searchParams.set('category', activeCategory)
      if (query) nextUrl.searchParams.set('q', searchInput?.value.trim() || '')
      else nextUrl.searchParams.delete('q')
      window.history.replaceState({}, '', nextUrl)
    }

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = button.dataset.category || 'All'
        applyFilters()
      })
    })

    searchInput.addEventListener('input', () => applyFilters())
    clearSearchButton.addEventListener('click', () => {
      searchInput.value = ''
      searchInput.focus()
      applyFilters()
    })

    resetButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = 'All'
        searchInput.value = ''
        applyFilters()
        searchInput.focus()
      })
    })

    applyFilters(false)
  }

  document.addEventListener('astro:page-load', initialisePostExplorer)
  initialisePostExplorer()
</script>

<style>
  .front-page {
    --display-serif: Georgia, Cambria, 'Times New Roman', Times, serif;
    display: block;
    padding-top: 2.5rem;
  }

  .masthead {
    border-top: 3px solid var(--text-primary);
    border-bottom: 1px solid var(--text-primary);
  }

  .masthead__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .masthead__rule {
    height: 1px;
    flex: 1;
    background: var(--border);
  }

  .masthead__body {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(16rem, 4fr);
    align-items: end;
    gap: 3rem;
    padding: 3.5rem 0 3rem;
  }

  .masthead h1 {
    max-width: 50rem;
    margin: 0;
    font-family: var(--display-serif);
    font-size: clamp(3.5rem, 7.4vw, 6.75rem);
    font-weight: 500;
    letter-spacing: -0.065em;
    line-height: 0.88;
    text-wrap: balance;
  }

  .masthead h1 em {
    color: var(--text-secondary);
    font-family: var(--serif);
    font-weight: 400;
  }

  .masthead__body > p {
    max-width: 27rem;
    margin: 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .masthead__index {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: var(--font-size-s);
  }

  .masthead__index strong {
    color: var(--text-primary);
    font-family: var(--mono);
    font-weight: 400;
  }

  .masthead__index a {
    margin-left: auto;
    color: var(--text-primary);
    text-decoration: none;
  }

  .explorer {
    padding-top: 6rem;
  }

  .explorer__heading {
    display: grid;
    grid-template-columns: 1fr minmax(18rem, 28rem);
    align-items: end;
    gap: 2rem;
  }

  .section-label,
  .story__flag {
    margin: 0 0 0.5rem;
    color: var(--text-secondary);
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.09em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .explorer h2 {
    margin: 0;
    font-family: var(--display-serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .search {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 3.25rem;
    border-bottom: 1px solid var(--text-primary);
  }

  .search svg {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.5;
  }

  .search input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text-primary);
    font: inherit;
    padding: 0.75rem;
  }

  .search input::placeholder {
    color: var(--text-secondary);
  }

  .search:focus-within {
    box-shadow: 0 2px 0 var(--text-primary);
  }

  .search__clear,
  .results-bar button,
  .empty-state button {
    border: 0;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .filters {
    display: flex;
    gap: 0;
    margin-top: 2.5rem;
    border-block: 1px solid var(--text-primary);
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .filter {
    min-height: 3.5rem;
    flex: 1 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    border: 0;
    border-right: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font: inherit;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }

  .filter:last-child {
    border-right: 0;
  }

  .filter:hover,
  .filter.is-active {
    background: var(--text-primary);
    color: var(--bg);
  }

  .filter__count {
    font-family: var(--mono);
    font-size: 0.7rem;
  }

  .results-bar {
    min-height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .results-bar p {
    margin: 0;
  }

  .front-page[data-filtered='false'] .results-bar button {
    visibility: hidden;
  }

  .story-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
  }

  .story {
    grid-column: span 4;
    min-width: 0;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--text-primary);
  }

  .story:nth-child(3n) {
    border-right: 0;
  }

  .story[hidden] {
    display: none !important;
  }

  .story > a {
    height: 100%;
    min-height: 24rem;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    color: inherit;
    padding: 1.5rem;
    text-decoration: none;
    transition:
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .story > a:hover {
    background: var(--surface);
  }

  .story__topline,
  .story__footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .story__topline {
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .story__body {
    flex: 1;
    padding-block: 1.5rem;
  }

  .story h3 {
    margin: 0;
    font-family: var(--display-serif);
    font-size: clamp(1.55rem, 2.4vw, 2.05rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.06;
    text-wrap: balance;
  }

  .story__description {
    display: -webkit-box;
    margin: 1rem 0 0;
    overflow: hidden;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }

  .story__footer {
    min-height: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .story__footer ul {
    min-width: 0;
    display: flex;
    gap: 0.375rem;
    margin: 0;
    padding: 0;
    overflow: hidden;
    list-style: none;
  }

  .story__footer li {
    flex: 0 0 auto;
  }

  .story__footer li:not(:last-child)::after {
    content: ' /';
    color: var(--text-tertiary);
  }

  .story__date {
    flex: 0 0 auto;
  }

  .story__arrow {
    margin-left: auto;
    color: var(--text-primary);
    font-size: 0.9rem;
  }

  .story--lead {
    grid-column: span 7;
    grid-row: span 2;
  }

  .story--lead > a {
    min-height: 48rem;
    padding: 2rem;
  }

  .story--lead .story__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 3rem;
  }

  .story--lead h3 {
    max-width: 44rem;
    font-size: clamp(3rem, 5.6vw, 5.25rem);
    letter-spacing: -0.055em;
    line-height: 0.94;
  }

  .story--lead .story__description {
    max-width: 38rem;
    font-size: 1.05rem;
    -webkit-line-clamp: 5;
  }

  .story--secondary {
    grid-column: span 5;
  }

  .story--secondary > a {
    min-height: 24rem;
  }

  .story--secondary h3 {
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
  }

  .front-page[data-filtered='true'] .story {
    grid-column: span 4;
    grid-row: auto;
  }

  .front-page[data-filtered='true'] .story > a {
    min-height: 24rem;
    padding: 1.5rem;
  }

  .front-page[data-filtered='true'] .story__body {
    display: block;
    padding-block: 1.5rem;
  }

  .front-page[data-filtered='true'] .story h3 {
    font-size: clamp(1.55rem, 2.4vw, 2.05rem);
    letter-spacing: -0.035em;
    line-height: 1.06;
  }

  .empty-state {
    padding: 6rem 1.5rem;
    border-bottom: 1px solid var(--text-primary);
    text-align: center;
  }

  .empty-state h3 {
    margin: 0;
    font-family: var(--display-serif);
    font-size: 2.25rem;
    font-weight: 500;
  }

  .empty-state > p:not(.section-label) {
    margin: 0.75rem auto 1.5rem;
    color: var(--text-secondary);
  }

  .empty-state button {
    min-height: 2.75rem;
    border: 1px solid var(--text-primary);
    color: var(--text-primary);
    padding: 0.625rem 1rem;
  }

  @media (max-width: 900px) {
    .masthead__body {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .masthead__body > p {
      max-width: 38rem;
    }

    .story,
    .front-page[data-filtered='true'] .story {
      grid-column: span 6;
    }

    .story:nth-child(3n) {
      border-right: 1px solid var(--border);
    }

    .story:nth-child(2n) {
      border-right: 0;
    }

    .story--lead {
      grid-column: span 12;
      grid-row: auto;
      border-right: 0;
    }

    .story--lead > a {
      min-height: 38rem;
    }

    .story--secondary {
      grid-column: span 6;
    }
  }

  @media (max-width: 680px) {
    .front-page {
      padding-top: 1.5rem;
    }

    .masthead__eyebrow > :last-child {
      display: none;
    }

    .masthead__body {
      padding: 2.5rem 0 2rem;
    }

    .masthead h1 {
      font-size: clamp(3rem, 16vw, 5rem);
      line-height: 0.92;
    }

    .masthead__index {
      align-items: flex-start;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .masthead__index a {
      width: 100%;
      margin: 0;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
    }

    .explorer {
      padding-top: 4.5rem;
    }

    .explorer__heading {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .filters {
      margin-inline: -1.25rem;
      padding-left: 1.25rem;
    }

    .filter:last-child {
      margin-right: 1.25rem;
      border-right: 1px solid var(--border);
    }

    .story,
    .story--lead,
    .story--secondary,
    .front-page[data-filtered='true'] .story {
      grid-column: span 12;
      border-right: 0;
    }

    .story > a,
    .story--lead > a,
    .front-page[data-filtered='true'] .story > a {
      min-height: 0;
      padding: 1.5rem 0;
    }

    .story--lead .story__body {
      min-height: 24rem;
      padding-block: 2.5rem;
    }

    .story--lead h3 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .story--secondary h3 {
      font-size: 2rem;
    }
  }
</style>
