---
/**
 * Unified Memory Architecture Diagram
 * Compares Apple Silicon unified memory with traditional discrete GPU architecture
 * Minimalist design with animated data transfer visualization
 */
interface Props {
  title?: string;
  showAnimation?: boolean;
}

const { title = 'Memory Architecture Comparison', showAnimation = true } = Astro.props;
---

<div class="memory-diagram" data-animate={showAnimation}>
  {title && <div class="diagram-title">{title}</div>}

  <div class="architectures">
    <!-- Traditional Discrete GPU -->
    <div class="arch-panel" data-type="discrete">
      <div class="arch-header">
        <span class="arch-name">Discrete GPU</span>
        <span class="arch-tag slow">Copy Required</span>
      </div>

      <div class="arch-visual">
        <!-- CPU Side -->
        <div class="memory-region cpu-region">
          <div class="region-label">CPU Memory</div>
          <div class="memory-pool">
            <div class="data-block source">
              <div class="block-bits">
                <span class="bit">1</span><span class="bit">0</span><span class="bit">1</span><span class="bit">1</span>
              </div>
              <span class="block-label">tensor</span>
            </div>
          </div>
          <div class="chip cpu-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="5" y="5" width="14" height="14" rx="1"/>
              <path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/>
            </svg>
            <span>CPU</span>
          </div>
        </div>

        <!-- Transfer Bus -->
        <div class="transfer-bus">
          <div class="bus-line">
            <div class="bus-arrow"></div>
          </div>
          <div class="bus-packets">
            <div class="packet p1"></div>
            <div class="packet p2"></div>
            <div class="packet p3"></div>
          </div>
          <div class="bus-info">
            <span class="bus-label">PCIe 4.0</span>
            <span class="bus-latency">~5-10ms</span>
          </div>
        </div>

        <!-- GPU Side -->
        <div class="memory-region gpu-region">
          <div class="region-label">GPU VRAM</div>
          <div class="memory-pool">
            <div class="data-block dest">
              <div class="block-bits">
                <span class="bit ghost">-</span><span class="bit ghost">-</span><span class="bit ghost">-</span><span class="bit ghost">-</span>
              </div>
              <span class="block-label">copy</span>
            </div>
          </div>
          <div class="chip gpu-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="6" width="18" height="12" rx="1"/>
              <path d="M7 10v4M10 10v4M13 10v4M16 10v4"/>
            </svg>
            <span>GPU</span>
          </div>
        </div>
      </div>

      <div class="arch-metrics">
        <div class="metric negative">
          <span class="metric-value">2x</span>
          <span class="metric-label">memory usage</span>
        </div>
        <div class="metric negative">
          <span class="metric-value">~32GB/s</span>
          <span class="metric-label">bandwidth limit</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="arch-divider">
      <span>vs</span>
    </div>

    <!-- Apple Silicon Unified Memory -->
    <div class="arch-panel" data-type="unified">
      <div class="arch-header">
        <span class="arch-name">Unified Memory</span>
        <span class="arch-tag fast">Zero Copy</span>
      </div>

      <div class="arch-visual unified">
        <div class="unified-pool">
          <div class="pool-label">Shared Memory Pool</div>
          <div class="pool-content">
            <div class="data-block shared">
              <div class="block-bits active">
                <span class="bit">1</span><span class="bit">0</span><span class="bit">1</span><span class="bit">1</span>
              </div>
              <span class="block-label">tensor</span>
            </div>
          </div>

          <div class="access-ring">
            <div class="ring-segment cpu-seg" data-processor="cpu"></div>
            <div class="ring-segment gpu-seg" data-processor="gpu"></div>
            <div class="ring-segment npu-seg" data-processor="npu"></div>
          </div>
        </div>

        <div class="unified-chips">
          <div class="chip cpu-chip" data-active="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="5" y="5" width="14" height="14" rx="1"/>
              <path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/>
            </svg>
            <span>CPU</span>
          </div>
          <div class="chip gpu-chip" data-active="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="6" width="18" height="12" rx="1"/>
              <path d="M7 10v4M10 10v4M13 10v4M16 10v4"/>
            </svg>
            <span>GPU</span>
          </div>
          <div class="chip npu-chip" data-active="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="7"/>
              <circle cx="12" cy="12" r="2"/>
              <path d="M12 5v2M12 17v2M5 12h2M17 12h2"/>
            </svg>
            <span>ANE</span>
          </div>
        </div>
      </div>

      <div class="arch-metrics">
        <div class="metric positive">
          <span class="metric-value">1x</span>
          <span class="metric-label">memory usage</span>
        </div>
        <div class="metric positive">
          <span class="metric-value">~400GB/s</span>
          <span class="metric-label">bandwidth</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom summary -->
  <div class="diagram-summary">
    <div class="summary-item">
      <span class="summary-check">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm3.5 5.5l-4 4-2-2-.7.7 2.7 2.7 4.7-4.7-.7-.7z"/></svg>
      </span>
      <span>No transfer overhead</span>
    </div>
    <div class="summary-item">
      <span class="summary-check">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm3.5 5.5l-4 4-2-2-.7.7 2.7 2.7 4.7-4.7-.7-.7z"/></svg>
      </span>
      <span>Full RAM for GPU</span>
    </div>
    <div class="summary-item">
      <span class="summary-check">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm3.5 5.5l-4 4-2-2-.7.7 2.7 2.7 4.7-4.7-.7-.7z"/></svg>
      </span>
      <span>Seamless processor handoff</span>
    </div>
  </div>
</div>

<script>
  function initMemoryDiagram() {
    document.querySelectorAll('.memory-diagram[data-animate="true"]').forEach((diagram) => {
      const sourceBlock = diagram.querySelector('.source');
      const destBlock = diagram.querySelector('.dest');
      const packets = diagram.querySelectorAll('.packet');
      const destBits = diagram.querySelectorAll('.dest .bit');
      const sharedBlock = diagram.querySelector('.shared');
      const ringSegments = diagram.querySelectorAll('.ring-segment');
      const unifiedChips = diagram.querySelectorAll('.unified-chips .chip');

      const sourceBits = ['1', '0', '1', '1'];

      const runAnimation = () => {
        // Reset
        sourceBlock?.classList.remove('sending');
        destBlock?.classList.remove('receiving', 'complete');
        packets.forEach(p => p.classList.remove('active', 'p1-go', 'p2-go', 'p3-go'));
        destBits.forEach((b, _i) => {
          b.textContent = '-';
          b.classList.add('ghost');
        });
        sharedBlock?.classList.remove('pulse');
        ringSegments.forEach(s => s.classList.remove('active'));
        unifiedChips.forEach(c => c.classList.remove('accessing'));

        // Discrete GPU animation: packets moving
        setTimeout(() => {
          sourceBlock?.classList.add('sending');
          packets[0]?.classList.add('active', 'p1-go');
        }, 300);

        setTimeout(() => {
          packets[1]?.classList.add('active', 'p2-go');
        }, 500);

        setTimeout(() => {
          packets[2]?.classList.add('active', 'p3-go');
        }, 700);

        setTimeout(() => {
          destBlock?.classList.add('receiving');
          destBits.forEach((b, i) => {
            setTimeout(() => {
              b.textContent = sourceBits[i];
              b.classList.remove('ghost');
            }, i * 150);
          });
        }, 1200);

        setTimeout(() => {
          destBlock?.classList.add('complete');
        }, 1800);

        // Unified memory animation: simultaneous access
        setTimeout(() => {
          sharedBlock?.classList.add('pulse');
        }, 400);

        // Ring segments light up sequentially
        ringSegments.forEach((seg, i) => {
          setTimeout(() => {
            seg.classList.add('active');
          }, 500 + i * 200);
        });

        // Chips show access
        unifiedChips.forEach((chip, i) => {
          setTimeout(() => {
            chip.classList.add('accessing');
          }, 700 + i * 200);
        });
      };

      runAnimation();
      const interval = setInterval(runAnimation, 4000);

      document.addEventListener('astro:before-swap', () => {
        clearInterval(interval);
      }, { once: true });
    });
  }

  initMemoryDiagram();
  document.addEventListener('astro:after-swap', initMemoryDiagram);
</script>

<style>
  .memory-diagram {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
  }

  .diagram-title {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }

  .architectures {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: start;
  }

  .arch-panel {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 1rem;
  }

  .arch-panel[data-type="unified"] {
    border-color: var(--text-secondary);
  }

  .arch-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.5rem;
  }

  .arch-name {
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .arch-tag {
    font-family: var(--mono);
    font-size: 0.5rem;
    padding: 0.15rem 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid;
  }

  .arch-tag.slow {
    background: transparent;
    color: var(--text-tertiary);
    border-color: var(--border);
  }

  .arch-tag.fast {
    background: var(--selection);
    color: var(--text-secondary);
    border-color: var(--text-secondary);
  }

  /* Discrete GPU Visual */
  .arch-visual {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-bottom: 1.25rem;
    min-height: 180px;
  }

  .memory-region {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .region-label {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .memory-pool {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 1rem 0.5rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
  }

  .data-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.3s ease;
  }

  .data-block.source.sending {
    border-color: var(--text-secondary);
    box-shadow: 0 0 0 2px var(--selection);
  }

  .data-block.dest {
    border-style: dashed;
    opacity: 0.5;
  }

  .data-block.dest.receiving {
    border-style: solid;
    opacity: 0.8;
  }

  .data-block.dest.complete {
    opacity: 1;
    border-color: var(--text-tertiary);
  }

  .block-bits {
    display: flex;
    gap: 0.2rem;
  }

  .bit {
    font-family: var(--mono);
    font-size: 0.65rem;
    width: 1.1rem;
    height: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--selection);
    color: var(--text-primary);
    font-weight: var(--font-weight-bold);
    transition: all 0.2s ease;
  }

  .bit.ghost {
    background: var(--code-bg);
    color: var(--text-tertiary);
  }

  .block-label {
    font-family: var(--mono);
    font-size: 0.5rem;
    color: var(--text-tertiary);
  }

  .chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    color: var(--text-tertiary);
    padding: 0.35rem;
    background: var(--bg);
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }

  .chip svg {
    width: 20px;
    height: 20px;
  }

  .chip span {
    font-family: var(--mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Transfer Bus */
  .transfer-bus {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 0.5rem;
    min-width: 60px;
    position: relative;
  }

  .bus-line {
    position: relative;
    width: 100%;
    height: 2px;
    background: var(--border);
    margin: 0.5rem 0;
  }

  .bus-arrow {
    position: absolute;
    right: -4px;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    border-left: 6px solid var(--text-tertiary);
  }

  .bus-packets {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: flex-start;
  }

  .packet {
    width: 6px;
    height: 6px;
    background: var(--text-secondary);
    border-radius: 50%;
    opacity: 0;
    position: absolute;
    left: 0;
    transition: left 0.6s ease-out, opacity 0.2s ease;
  }

  .packet.active {
    opacity: 1;
  }

  .packet.p1-go { left: calc(100% - 6px); transition-delay: 0s; }
  .packet.p2-go { left: calc(100% - 6px); transition-delay: 0.1s; }
  .packet.p3-go { left: calc(100% - 6px); transition-delay: 0.2s; }

  .bus-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .bus-label {
    font-family: var(--mono);
    font-size: 0.5rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }

  .bus-latency {
    font-family: var(--mono);
    font-size: 0.5rem;
    color: var(--text-tertiary);
    opacity: 0.7;
  }

  /* Unified Memory Visual */
  .arch-visual.unified {
    flex-direction: column;
    gap: 1rem;
  }

  .unified-pool {
    position: relative;
    padding: 1.25rem;
    background: var(--selection);
    border: 1px solid var(--text-tertiary);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .pool-label {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pool-content {
    display: flex;
    justify-content: center;
  }

  .data-block.shared {
    background: var(--bg);
    border-color: var(--text-secondary);
  }

  .data-block.shared.pulse {
    animation: pulse-glow 0.8s ease-out;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 var(--selection); }
    50% { box-shadow: 0 0 0 8px transparent; }
  }

  .access-ring {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .ring-segment {
    width: 32px;
    height: 3px;
    background: var(--border);
    transition: all 0.3s ease;
  }

  .ring-segment.active {
    background: var(--text-secondary);
  }

  .unified-chips {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .unified-chips .chip {
    transition: all 0.3s ease;
  }

  .unified-chips .chip.accessing {
    color: var(--text-primary);
  }

  .unified-chips .chip.accessing svg {
    filter: drop-shadow(0 0 4px var(--text-tertiary));
  }

  /* Metrics */
  .arch-metrics {
    display: flex;
    gap: 0.75rem;
    padding-top: 0.75rem;
    margin-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .metric {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.35rem 0.5rem;
    background: var(--code-bg);
  }

  .metric-value {
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .metric-label {
    font-family: var(--mono);
    font-size: 0.45rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric.negative .metric-value {
    color: var(--text-tertiary);
  }

  .metric.positive .metric-value {
    color: var(--text-primary);
  }

  /* Divider */
  .arch-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.5rem;
  }

  .arch-divider span {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--text-tertiary);
    text-transform: lowercase;
  }

  /* Summary */
  .diagram-summary {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .summary-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .summary-check {
    width: 10px;
    height: 10px;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .summary-check svg {
    width: 100%;
    height: 100%;
  }

  .summary-item span:last-child {
    font-family: var(--mono);
    font-size: 0.5rem;
    color: var(--text-tertiary);
  }

  /* Responsive */
  @media (max-width: 700px) {
    .architectures {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .arch-divider {
      padding: 0.5rem 0;
    }

    .arch-visual {
      flex-direction: column;
      gap: 0.5rem;
    }

    .transfer-bus {
      flex-direction: row;
      padding: 0.5rem;
      min-width: auto;
    }

    .bus-line {
      width: 40px;
      margin: 0 0.5rem;
    }

    .diagram-summary {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
