---
const heads = [
  ['next', 'token t+1', 'shared trunk'],
  ['second', 'token t+2', 'independent head'],
  ['third', 'token t+3', 'independent head'],
  ['fourth', 'token t+4', 'independent head']
]
---

<figure class="viz" aria-labelledby="mtp-title" data-mtp-motion>
  <div class="viz-header">
    <figcaption id="mtp-title">One hidden state supervises several future-token heads</figcaption>
    <button type="button" data-replay aria-label="Replay multi-token prediction sequence"
      >Replay</button
    >
  </div>
  <div class="trunk">
    <span>tokens through t</span><b>Transformer trunk</b><span>hidden state hₜ</span>
  </div>
  <div class="fan" aria-hidden="true">↙ ↓ ↓ ↘</div>
  <div class="heads">
    {
      heads.map((head, index) => (
        <section style={`--delay:${420 + index * 70}ms`}>
          <>
            <small>{head[0]}</small>
            <strong>{head[1]}</strong>
            <span>{head[2]}</span>
          </>
        </section>
      ))
    }
  </div>
  <div class="loss">L = Σ α<sub>k</sub> CE(p<sub>t+k</sub>, x<sub>t+k</sub>)</div>
</figure>
<style>
  .viz {
    margin: 2em 0;
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: var(--astro-code-background);
    color: var(--text-primary);
  }
  figcaption {
    font: 600 var(--font-size-s) var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .viz-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  button {
    min-width: 4.5rem;
    min-height: 2.75rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-secondary);
    font: 0.72rem var(--mono);
    cursor: pointer;
    transition:
      transform 140ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 140ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  button:active {
    transform: scale(0.97);
  }
  button:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }
  .trunk {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font: 0.76rem var(--mono);
  }
  .trunk b {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-top: 3px solid var(--text-secondary);
    background: var(--bg);
  }
  .fan {
    text-align: center;
    letter-spacing: 2rem;
    color: var(--text-tertiary);
    margin: 0.65rem;
  }
  .heads {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.55rem;
  }
  .heads section {
    display: grid;
    gap: 0.35rem;
    padding: 0.8rem;
    border: 1px solid var(--border);
    background: var(--bg);
  }
  small,
  section span {
    font: 0.72rem var(--mono);
    color: var(--text-tertiary);
  }
  strong {
    font: 0.78rem var(--mono);
  }
  .loss {
    text-align: center;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font: 0.8rem var(--mono);
  }
  .motion-ready:not(.is-running) .trunk,
  .motion-ready:not(.is-running) .fan,
  .motion-ready:not(.is-running) .heads section,
  .motion-ready:not(.is-running) .loss {
    opacity: 0;
    transform: translateY(8px);
  }
  .motion-ready.is-running .trunk {
    animation: mtp-enter 360ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  .motion-ready.is-running .fan {
    animation: mtp-enter 300ms 240ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  .motion-ready.is-running .heads section {
    animation: mtp-enter 360ms var(--delay) cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  .motion-ready.is-running .loss {
    animation: mtp-enter 360ms 820ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  @keyframes mtp-enter {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (hover: hover) and (pointer: fine) {
    button:hover {
      opacity: 0.72;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    button {
      display: none;
    }
    .motion-ready * {
      animation: none !important;
      opacity: 1 !important;
    }
  }
  @media (max-width: 620px) {
    .viz-header {
      align-items: flex-start;
    }
    .trunk {
      flex-direction: column;
    }
    .fan {
      letter-spacing: 0.8rem;
    }
    .heads {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-mtp-motion]').forEach((figure) => {
    if (figure.dataset.motionBound || matchMedia('(prefers-reduced-motion: reduce)').matches) return

    figure.dataset.motionBound = 'true'
    figure.classList.add('motion-ready')

    const play = () => {
      figure.classList.remove('is-running')
      void figure.offsetWidth
      figure.classList.add('is-running')
    }

    figure.querySelector('[data-replay]')?.addEventListener('click', play)
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return
        play()
        observer.disconnect()
      },
      { threshold: 0.35 }
    )
    observer.observe(figure)
  })
</script>
