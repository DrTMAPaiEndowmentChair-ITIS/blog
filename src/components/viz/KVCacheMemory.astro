---
const rows = [
  { token: 'System', blocks: ['K0', 'V0'], shared: true },
  { token: 'Prompt', blocks: ['K1', 'V1'], shared: true },
  { token: 'Answer A', blocks: ['K2', 'V2'], shared: false },
  { token: 'Answer B', blocks: ['K3', 'V3'], shared: false }
]
---

<figure class="viz" aria-labelledby="kv-title">
  <figcaption id="kv-title">Logical sequences map to reusable physical KV blocks</figcaption>
  <div class="layout">
    <div class="logical">
      <strong>Logical token blocks</strong>
      {
        rows.map((row) => (
          <div class:list={['row', { shared: row.shared }]}>
            <>
              <span>{row.token}</span>
              <code>{row.blocks.join(' · ')}</code>
            </>
          </div>
        ))
      }
    </div>
    <div class="arrow" aria-hidden="true">→</div>
    <div class="physical">
      <strong>Physical GPU pages</strong>
      <div class="pages">
        {
          ['K0/V0', 'K2/V2', 'K1/V1', 'free', 'K3/V3', 'free'].map((page) => (
            <code class:list={{ free: page === 'free' }}>{page}</code>
          ))
        }
      </div>
      <small>Block table removes the requirement for contiguous allocation.</small>
    </div>
  </div>
  <div class="legend"><i></i> Prefix blocks can be referenced by more than one request</div>
</figure>

<style>
  .viz {
    margin: 2em 0;
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: var(--astro-code-background);
    color: var(--text-primary);
  }
  figcaption {
    font: 600 var(--font-size-s) var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
  }
  .layout {
    display: grid;
    grid-template-columns: 1fr auto 1.2fr;
    gap: 1rem;
    align-items: center;
  }
  .logical,
  .physical {
    display: grid;
    gap: 0.6rem;
  }
  strong,
  small {
    font-family: var(--mono);
  }
  .row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem;
    border-left: 3px solid var(--border);
    background: var(--bg);
  }
  .row.shared {
    border-color: var(--text-secondary);
  }
  code {
    font-size: 0.8rem;
  }
  .arrow {
    font-size: 1.5rem;
    color: var(--text-tertiary);
  }
  .pages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
  }
  .pages code {
    padding: 0.7rem 0.35rem;
    text-align: center;
    border: 1px solid var(--border);
    background: var(--bg);
  }
  .pages .free {
    border-style: dashed;
    color: var(--text-tertiary);
  }
  small {
    color: var(--text-tertiary);
    line-height: 1.5;
  }
  .legend {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font: 0.78rem var(--mono);
    color: var(--text-secondary);
  }
  .legend i {
    display: inline-block;
    width: 18px;
    border-top: 3px solid var(--text-secondary);
    margin-right: 0.5rem;
  }
  @media (max-width: 620px) {
    .layout {
      grid-template-columns: 1fr;
    }
    .arrow {
      transform: rotate(90deg);
      text-align: center;
    }
    .pages {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
