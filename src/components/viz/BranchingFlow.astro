---
/**
 * Branching Flow Visualization
 * For diagrams with parallel branches that merge, like voice conversion
 */
interface Node {
  id: string;
  label: string;
  sublabel?: string;
  color?: 'accent' | 'highlight' | 'muted';
}

interface Props {
  title?: string;
  inputLabel?: string;
  outputLabel?: string;
  leftBranch: Node[];
  rightBranch: Node[];
  mergeNode: Node;
  postMerge?: Node[];
  leftLabel?: string;
  rightLabel?: string;
}

const {
  title,
  inputLabel = "Input",
  outputLabel = "Output",
  leftBranch,
  rightBranch,
  mergeNode,
  postMerge = [],
  leftLabel,
  rightLabel
} = Astro.props;
---

<div class="branching-flow">
  {title && <div class="flow-title">{title}</div>}

  <div class="flow-container">
    <div class="io-node input">{inputLabel}</div>
    <div class="connector down"></div>

    <div class="branch-section">
      <div class="branch left">
        {leftLabel && <div class="branch-label">{leftLabel}</div>}
        {leftBranch.map((node, index) => (
          <>
            <div class={`node-box ${node.color || 'muted'}`}>
              <div class="node-label">{node.label}</div>
              {node.sublabel && <div class="node-sublabel">{node.sublabel}</div>}
            </div>
            {index < leftBranch.length - 1 && <div class="connector down small"></div>}
          </>
        ))}
      </div>

      <div class="branch-connector">
        <div class="h-line"></div>
      </div>

      <div class="branch right">
        {rightLabel && <div class="branch-label">{rightLabel}</div>}
        {rightBranch.map((node, index) => (
          <>
            <div class={`node-box ${node.color || 'muted'}`}>
              <div class="node-label">{node.label}</div>
              {node.sublabel && <div class="node-sublabel">{node.sublabel}</div>}
            </div>
            {index < rightBranch.length - 1 && <div class="connector down small"></div>}
          </>
        ))}
      </div>
    </div>

    <div class="merge-connectors">
      <div class="merge-line left"></div>
      <div class="merge-line right"></div>
    </div>

    <div class={`node-box merge ${mergeNode.color || 'highlight'}`}>
      <div class="node-label">{mergeNode.label}</div>
      {mergeNode.sublabel && <div class="node-sublabel">{mergeNode.sublabel}</div>}
    </div>

    {postMerge.map((node) => (
      <>
        <div class="connector down"></div>
        <div class={`node-box ${node.color || 'muted'}`}>
          <div class="node-label">{node.label}</div>
          {node.sublabel && <div class="node-sublabel">{node.sublabel}</div>}
        </div>
      </>
    ))}

    <div class="connector down"></div>
    <div class="io-node output">{outputLabel}</div>
  </div>
</div>

<style>
  .branching-flow {
    margin: 2em 0;
    padding: 1.5rem;
    background: var(--astro-code-background);
    border: 1px solid var(--border);
  }

  .flow-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .flow-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .io-node {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    padding: 0.375rem 0.75rem;
    background: var(--bg);
    border: 1px dashed var(--border);
  }

  .connector {
    width: 2px;
    height: 16px;
    background: var(--border);
    position: relative;
  }

  .connector.small {
    height: 10px;
  }

  .connector.down::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid var(--border);
  }

  .branch-section {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin: 0.5rem 0;
  }

  .branch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .branch-label {
    font-family: var(--mono);
    font-size: 0.5rem;
    color: var(--text-tertiary);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .branch-connector {
    display: flex;
    align-items: center;
    padding-top: 2rem;
  }

  .h-line {
    width: 20px;
    height: 2px;
    background: var(--border);
  }

  .merge-connectors {
    display: flex;
    width: 100%;
    max-width: 240px;
    justify-content: space-between;
    height: 16px;
    position: relative;
  }

  .merge-line {
    width: 2px;
    height: 100%;
    background: var(--border);
  }

  .merge-line.left {
    margin-left: 25%;
  }

  .merge-line.right {
    margin-right: 25%;
  }

  .node-box {
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    text-align: center;
    min-width: 90px;
  }

  .node-box.merge {
    min-width: 140px;
  }

  .node-box.accent {
    border-left: 3px solid var(--text-secondary);
  }

  .node-box.highlight {
    border-left: 3px solid var(--text-tertiary);
    background: var(--selection);
  }

  .node-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .node-sublabel {
    font-size: 0.5rem;
    color: var(--text-tertiary);
    margin-top: 0.125rem;
  }

  @media (max-width: 500px) {
    .branch-section {
      flex-direction: column;
      gap: 0.5rem;
    }

    .branch-connector {
      transform: rotate(90deg);
      padding: 0;
    }

    .merge-connectors {
      display: none;
    }
  }
</style>
