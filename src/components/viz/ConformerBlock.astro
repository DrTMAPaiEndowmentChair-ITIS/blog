---
/**
 * Conformer Block Visualization
 * Shows the "macaron" structure with sandwich pattern
 */
interface Module {
  name: string;
  details?: string[];
  annotation?: string;
  color?: 'accent' | 'highlight' | 'muted';
}

interface Props {
  title?: string;
  modules?: Module[];
}

const { title = "Conformer Block Structure" } = Astro.props;

const defaultModules: Module[] = [
  {
    name: "Feed-Forward (half-step)",
    details: ["x + 0.5 * FFN(x)"],
    annotation: 'First "bun"',
    color: "accent"
  },
  {
    name: "Multi-Head Self-Attention",
    details: ["+ Relative Positional Encoding"],
    color: "highlight"
  },
  {
    name: "Convolution Module",
    details: [
      "Pointwise Conv (2x expand)",
      "GLU activation",
      "Depthwise Conv (kernel=31)",
      "BatchNorm",
      "Swish activation",
      "Pointwise Conv (compress)"
    ],
    annotation: 'The "filling"',
    color: "highlight"
  },
  {
    name: "Feed-Forward (half-step)",
    details: ["x + 0.5 * FFN(x)"],
    annotation: 'Second "bun"',
    color: "accent"
  },
  {
    name: "LayerNorm",
    color: "muted"
  }
];

const modules = Astro.props.modules || defaultModules;
---

<div class="conformer-block">
  <div class="block-title">{title}</div>

  <div class="block-container">
    <div class="io-node input">Input</div>
    <div class="connector down"></div>

    {modules.map((module, index) => (
      <>
        <div class={`module-box ${module.color || 'muted'}`}>
          <div class="module-content">
            <div class="module-name">{module.name}</div>
            {module.details && (
              <div class="module-details">
                {module.details.map(detail => (
                  <div class="detail-item">{detail}</div>
                ))}
              </div>
            )}
          </div>
          {module.annotation && (
            <div class="module-annotation">{module.annotation}</div>
          )}
        </div>
        {index < modules.length - 1 && <div class="connector down"></div>}
      </>
    ))}

    <div class="connector down"></div>
    <div class="io-node output">Output</div>
  </div>
</div>

<style>
  .conformer-block {
    margin: 2em 0;
    padding: 1.5rem;
    background: var(--astro-code-background);
    border: 1px solid var(--border);
  }

  .block-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .block-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .io-node {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    padding: 0.375rem 0.75rem;
    background: var(--bg);
    border: 1px dashed var(--border);
  }

  .connector {
    width: 2px;
    height: 16px;
    background: var(--border);
    position: relative;
  }

  .connector.down::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid var(--border);
  }

  .module-box {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    width: 100%;
    max-width: 320px;
    position: relative;
  }

  .module-box.accent {
    border-left: 3px solid var(--text-secondary);
  }

  .module-box.highlight {
    border-left: 3px solid var(--text-tertiary);
    background: var(--selection);
  }

  .module-content {
    flex: 1;
  }

  .module-name {
    font-family: var(--mono);
    font-size: 0.8125rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .module-details {
    margin-top: 0.375rem;
  }

  .detail-item {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    padding-left: 0.5rem;
    border-left: 1px solid var(--border);
    margin-top: 0.125rem;
  }

  .module-annotation {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    font-style: italic;
    white-space: nowrap;
    position: absolute;
    right: -8rem;
    width: 7rem;
  }

  @media (max-width: 600px) {
    .module-annotation {
      position: static;
      margin-top: 0.5rem;
      text-align: center;
      width: auto;
    }

    .module-box {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
