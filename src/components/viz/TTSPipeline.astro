---
/**
 * TTS Pipeline Visualization
 * Vertical flow diagram for text-to-speech architectures
 */
interface Stage {
  id: string;
  label: string;
  sublabel?: string;
  details?: string[];
  annotation?: string;
  color?: 'accent' | 'highlight' | 'muted';
}

interface Props {
  title?: string;
  subtitle?: string;
  inputLabel?: string;
  outputLabel?: string;
  stages: Stage[];
}

const {
  title,
  subtitle,
  inputLabel = "Input",
  outputLabel = "Output",
  stages
} = Astro.props;
---

<div class="tts-pipeline">
  {title && (
    <div class="pipeline-header">
      <div class="pipeline-title">{title}</div>
      {subtitle && <div class="pipeline-subtitle">{subtitle}</div>}
    </div>
  )}

  <div class="pipeline-container">
    <div class="io-node input">{inputLabel}</div>
    <div class="connector down"></div>

    {stages.map((stage, index) => (
      <>
        <div class={`stage-box ${stage.color || 'muted'}`} data-stage-id={stage.id}>
          <div class="stage-content">
            <div class="stage-label">{stage.label}</div>
            {stage.sublabel && <div class="stage-sublabel">{stage.sublabel}</div>}
            {stage.details && (
              <div class="stage-details">
                {stage.details.map(detail => (
                  <div class="detail-line">{detail}</div>
                ))}
              </div>
            )}
          </div>
          {stage.annotation && (
            <div class="stage-annotation">{stage.annotation}</div>
          )}
        </div>
        {index < stages.length - 1 && <div class="connector down"></div>}
      </>
    ))}

    <div class="connector down"></div>
    <div class="io-node output">{outputLabel}</div>
  </div>
</div>

<style>
  .tts-pipeline {
    margin: 2em 0;
    padding: 1.5rem;
    background: var(--astro-code-background);
    border: 1px solid var(--border);
  }

  .pipeline-header {
    margin-bottom: 1.5rem;
  }

  .pipeline-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pipeline-subtitle {
    font-size: 0.6rem;
    color: var(--text-tertiary);
    margin-top: 0.25rem;
  }

  .pipeline-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    overflow: visible;
  }

  .io-node {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    padding: 0.375rem 0.75rem;
    background: var(--bg);
    border: 1px dashed var(--border);
  }

  .connector {
    width: 2px;
    height: 16px;
    background: var(--border);
    position: relative;
  }

  .connector.down::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid var(--border);
  }

  .stage-box {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    width: 100%;
    max-width: 300px;
    box-sizing: border-box;
  }

  .stage-box.accent {
    border-left: 3px solid var(--text-secondary);
  }

  .stage-box.highlight {
    border-left: 3px solid var(--text-tertiary);
    background: var(--selection);
  }

  .stage-content {
    flex: 1;
  }

  .stage-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .stage-sublabel {
    font-size: 0.55rem;
    color: var(--text-tertiary);
    margin-top: 0.125rem;
  }

  .stage-details {
    margin-top: 0.375rem;
    padding-left: 0.5rem;
    border-left: 1px solid var(--border);
  }

  .detail-line {
    font-family: var(--mono);
    font-size: 0.5rem;
    color: var(--text-tertiary);
    margin-top: 0.125rem;
  }

  .stage-annotation {
    font-size: 0.5rem;
    color: var(--text-tertiary);
    font-style: italic;
    line-height: 1.4;
    padding-top: 0.25rem;
    border-top: 1px dashed var(--border);
  }
</style>
