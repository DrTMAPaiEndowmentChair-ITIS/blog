<figure class="viz kv-estimator" aria-labelledby="kv-estimator-title" data-kv-estimator>
  <figcaption id="kv-estimator-title">Context length becomes a KV-cache memory bill</figcaption>

  <div class="formula">
    <span>2</span><b>×</b><span>layers</span><b>×</b><span>KV heads</span><b>×</b><span
      >head width</span
    ><b>×</b><span>bytes</span><b>×</b><span>cached tokens</span>
  </div>

  <div class="controls">
    <label><span>Layers</span><input data-layers type="number" min="1" step="1" value="32" /></label
    >
    <label><span>KV heads</span><input data-heads type="number" min="1" step="1" value="8" /></label
    >
    <label
      ><span>Head width</span><input data-width type="number" min="1" step="1" value="128" /></label
    >
    <label
      ><span>Bytes per value</span><input
        data-bytes
        type="number"
        min="0.25"
        step="0.25"
        value="2"
      /></label
    >
  </div>

  <div class="contexts">
    <button type="button" data-tokens="4096" aria-pressed="false">4,096 tokens</button>
    <button type="button" data-tokens="8192" aria-pressed="true">8,192 tokens</button>
    <button type="button" data-tokens="32768" aria-pressed="false">32,768 tokens</button>
    <button type="button" data-tokens="131072" aria-pressed="false">131,072 tokens</button>
  </div>

  <div class="output" aria-live="polite">
    <div>
      <span>Per cached token</span>
      <strong data-per-token>128 KiB</strong>
    </div>
    <div>
      <span>Selected context</span>
      <strong data-total>1.00 GiB</strong>
    </div>
  </div>

  <p>
    These are derived tensor values for the inputs shown. Sliding-window attention, cache
    quantization, offload, batching, and runtime allocation can change the memory that is resident
    on one device.
  </p>
</figure>

<style>
  .viz {
    container-type: inline-size;
    margin: 2em 0;
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: var(--astro-code-background);
    color: var(--text-primary);
  }
  figcaption {
    margin-bottom: 1rem;
    font: 600 var(--font-size-s) var(--mono);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .formula {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.8rem;
    font: 0.66rem var(--mono);
  }
  .formula span {
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
  }
  .formula b {
    color: var(--text-tertiary);
    font-weight: 400;
  }
  .controls {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--border);
    background: var(--bg);
  }
  label {
    display: grid;
    gap: 0.4rem;
    padding: 0.7rem;
    border-right: 1px solid var(--border);
  }
  label:last-child {
    border-right: 0;
  }
  label span,
  .output span,
  p {
    color: var(--text-secondary);
    font: 0.65rem/1.45 var(--mono);
  }
  input {
    box-sizing: border-box;
    width: 100%;
    min-height: 2.4rem;
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: var(--code-bg);
    color: var(--text-primary);
    font: 0.8rem var(--mono);
  }
  .contexts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 0.75rem;
    border: 1px solid var(--border);
  }
  button {
    min-height: 2.7rem;
    padding: 0.45rem;
    border: 0;
    border-right: 1px solid var(--border);
    border-radius: 0;
    background: var(--bg);
    color: var(--text-tertiary);
    font: 0.63rem var(--mono);
    cursor: pointer;
  }
  button:last-child {
    border-right: 0;
  }
  button[aria-pressed='true'] {
    color: var(--text-primary);
    box-shadow: inset 0 -2px 0 var(--text-primary);
  }
  .output {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-top: 0.8rem;
    border-top: 2px solid var(--text-primary);
  }
  .output div {
    display: grid;
    gap: 0.3rem;
    padding: 0.75rem 0.1rem;
  }
  .output div:last-child {
    padding-left: 0.8rem;
    border-left: 1px solid var(--border);
  }
  .output strong {
    font: 600 1rem var(--mono);
  }
  p {
    margin: 0.6rem 0 0;
  }
  @container (max-width: 540px) {
    .controls,
    .contexts {
      grid-template-columns: 1fr 1fr;
    }
    label:nth-child(2),
    button:nth-child(2) {
      border-right: 0;
    }
    label:nth-child(-n + 2),
    button:nth-child(-n + 2) {
      border-bottom: 1px solid var(--border);
    }
  }
  @container (max-width: 390px) {
    .controls,
    .contexts,
    .output {
      grid-template-columns: 1fr;
    }
    label,
    button {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }
    .output div:last-child {
      padding-left: 0.1rem;
      border-top: 1px solid var(--border);
      border-left: 0;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-kv-estimator]').forEach((root) => {
    if (root.dataset.bound) return
    root.dataset.bound = 'true'

    const layers = root.querySelector<HTMLInputElement>('[data-layers]')
    const heads = root.querySelector<HTMLInputElement>('[data-heads]')
    const width = root.querySelector<HTMLInputElement>('[data-width]')
    const bytes = root.querySelector<HTMLInputElement>('[data-bytes]')
    const perToken = root.querySelector<HTMLElement>('[data-per-token]')
    const total = root.querySelector<HTMLElement>('[data-total]')
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tokens]'))
    if (!layers || !heads || !width || !bytes || !perToken || !total) return

    let tokens = 8192
    const formatBytes = (value: number) => {
      if (value >= 2 ** 30) return `${(value / 2 ** 30).toFixed(2)} GiB`
      if (value >= 2 ** 20) return `${(value / 2 ** 20).toFixed(2)} MiB`
      return `${(value / 2 ** 10).toFixed(0)} KiB`
    }
    const update = () => {
      const bytesPerToken =
        2 *
        Math.max(0, Number(layers.value)) *
        Math.max(0, Number(heads.value)) *
        Math.max(0, Number(width.value)) *
        Math.max(0, Number(bytes.value))
      perToken.textContent = formatBytes(bytesPerToken)
      total.textContent = formatBytes(bytesPerToken * tokens)
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        tokens = Number(button.dataset.tokens)
        buttons.forEach((candidate) =>
          candidate.setAttribute('aria-pressed', String(candidate === button))
        )
        update()
      })
    })
    ;[layers, heads, width, bytes].forEach((input) => input.addEventListener('input', update))
    update()
  })
</script>
