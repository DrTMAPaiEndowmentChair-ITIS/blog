---
/**
 * Edge deployment stack visualization
 * Shows the software stack for different edge platforms
 */
interface StackLayer {
  name: string;
  description: string;
  highlight?: boolean;
}

interface Platform {
  name: string;
  layers: StackLayer[];
  color: 'jetson' | 'mobile' | 'browser' | 'rpi';
}

interface Props {
  title?: string;
}

const { title = "Edge Deployment Software Stacks" } = Astro.props;

const platforms: Platform[] = [
  {
    name: "NVIDIA Jetson",
    color: "jetson",
    layers: [
      { name: "Application", description: "Python / C++" },
      { name: "TensorRT", description: "Optimized inference", highlight: true },
      { name: "cuDNN / CUDA", description: "GPU acceleration" },
      { name: "JetPack SDK", description: "L4T Linux" },
      { name: "Hardware", description: "Ampere GPU + DLA" },
    ]
  },
  {
    name: "Apple CoreML",
    color: "mobile",
    layers: [
      { name: "Application", description: "Swift / Obj-C" },
      { name: "Core ML", description: "Model inference", highlight: true },
      { name: "BNNS / MPS", description: "Neural / GPU compute" },
      { name: "iOS / macOS", description: "Operating system" },
      { name: "Hardware", description: "ANE + GPU + CPU" },
    ]
  },
  {
    name: "Browser WebGPU",
    color: "browser",
    layers: [
      { name: "Application", description: "JavaScript / TS" },
      { name: "Transformers.js", description: "ML pipelines", highlight: true },
      { name: "ONNX Runtime Web", description: "Model execution" },
      { name: "WebGPU / WASM", description: "Compute backend" },
      { name: "Hardware", description: "GPU / CPU" },
    ]
  },
  {
    name: "Raspberry Pi + Hailo",
    color: "rpi",
    layers: [
      { name: "Application", description: "Python / C++" },
      { name: "HailoRT", description: "NPU runtime", highlight: true },
      { name: "rpicam-apps", description: "Camera pipeline" },
      { name: "Raspberry Pi OS", description: "Linux" },
      { name: "Hardware", description: "Hailo-8L NPU" },
    ]
  },
];
---

<div class="deployment-stack">
  <div class="stack-title">{title}</div>
  <div class="platforms-grid">
    {platforms.map((platform) => (
      <div class={`platform-column ${platform.color}`}>
        <div class="platform-header">{platform.name}</div>
        <div class="layers-container">
          {platform.layers.map((layer, index) => (
            <div class={`layer ${layer.highlight ? 'highlighted' : ''}`}>
              <div class="layer-name">{layer.name}</div>
              <div class="layer-desc">{layer.description}</div>
              {index < platform.layers.length - 1 && (
                <div class="layer-arrow">↓</div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .deployment-stack {
    margin: 2em 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .stack-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    min-width: 700px;
  }

  .platform-column {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .platform-header {
    padding: 0.75rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom: 1px solid var(--border);
  }

  .platform-column.jetson .platform-header {
    background: var(--selection);
    color: var(--text-primary);
  }

  .platform-column.mobile .platform-header {
    background: var(--astro-code-background);
    color: var(--text-primary);
  }

  .platform-column.browser .platform-header {
    background: var(--code-bg);
    color: var(--text-primary);
  }

  .platform-column.rpi .platform-header {
    background: var(--border);
    color: var(--text-primary);
  }

  .layers-container {
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
    gap: 0.25rem;
  }

  .layer {
    padding: 0.5rem;
    background: var(--astro-code-background);
    border: 1px solid transparent;
    text-align: center;
    transition: all 0.15s ease-out;
  }

  .layer.highlighted {
    background: var(--selection);
    border-color: var(--text-tertiary);
  }

  .layer-name {
    font-size: 0.8rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-bottom: 0.125rem;
  }

  .layer-desc {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--text-secondary);
  }

  .layer-arrow {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    margin-top: 0.25rem;
  }

  .layer:hover {
    transform: translateX(2px);
    border-color: var(--border);
  }

  @media (max-width: 800px) {
    .platforms-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .platforms-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
