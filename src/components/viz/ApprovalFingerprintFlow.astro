<figure class="approval-viz" aria-labelledby="approval-title">
  <figcaption id="approval-title">Approval binds to the exact action arguments</figcaption>
  <div class="flow">
    <section class="proposal">
      <span>model proposal</span>
      <code>refund(invoice, recipient A)</code>
    </section>
    <i aria-hidden="true">→</i>
    <section>
      <span>approval fingerprint</span>
      <code>H(tool, args, principal)</code>
    </section>
    <i aria-hidden="true">→</i>
    <section>
      <span>user approval</span>
      <code>approved: H₁</code>
    </section>
  </div>
  <div class="mutation">
    <span>arguments change after approval</span>
    <code>refund(invoice, recipient B)</code>
    <strong>H₂ ≠ H₁</strong>
    <b>deny and request approval again</b>
  </div>
  <p>
    Tool name, material arguments, and principal form one authorization unit. Session-wide approval
    cannot safely cover a changed destination.
  </p>
</figure>

<script>
  function initializeApprovalFingerprint() {
    if (!('IntersectionObserver' in window)) return
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return

    document.querySelectorAll<HTMLElement>('.approval-viz').forEach((figure) => {
      if (figure.dataset.motionReady) return
      figure.dataset.motionReady = 'true'
      figure.classList.add('can-animate')
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry?.isIntersecting) return
          figure.classList.add('is-visible')
          observer.disconnect()
        },
        { threshold: 0.2 }
      )
      observer.observe(figure)
    })
  }

  initializeApprovalFingerprint()
  document.addEventListener('astro:page-load', initializeApprovalFingerprint)
</script>

<style>
  .approval-viz {
    margin: 2rem 0;
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--code-bg);
  }

  figcaption {
    margin-bottom: 0.75rem;
    font: 600 0.8125rem/1.45 var(--mono);
  }

  .flow {
    display: flex;
    align-items: stretch;
    gap: 0.35rem;
  }

  .flow section {
    display: flex;
    flex: 1;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.65rem;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .flow i {
    align-self: center;
    color: var(--text-tertiary);
    font-style: normal;
  }

  .flow span,
  .mutation > span {
    color: var(--text-secondary);
    font-size: 0.6875rem;
    line-height: 1.35;
  }

  code {
    overflow-wrap: anywhere;
    font: 0.6875rem/1.4 var(--mono);
  }

  .mutation {
    display: grid;
    grid-template-columns: 1fr 1.5fr auto;
    gap: 0.4rem 0.65rem;
    align-items: center;
    margin-top: 0.6rem;
    padding: 0.65rem;
    border: 1px dashed var(--text-secondary);
    background: var(--bg);
    opacity: 1;
    transform: none;
  }

  .can-animate:not(.is-visible) .mutation {
    opacity: 0;
    transform: translateY(-0.35rem);
  }

  .can-animate.is-visible .mutation {
    animation: approval-mutation 300ms cubic-bezier(0.23, 1, 0.32, 1) 600ms both;
  }

  .mutation strong {
    font: 600 0.75rem/1.3 var(--mono);
  }

  .mutation b {
    grid-column: 1 / -1;
    padding-top: 0.45rem;
    border-top: 1px solid var(--border);
    font: 600 0.6875rem/1.4 var(--mono);
    text-align: center;
  }

  p {
    margin: 0.75rem 0 0;
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  @keyframes approval-mutation {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 560px) {
    .flow {
      flex-direction: column;
    }

    .flow i {
      rotate: 90deg;
    }

    .mutation {
      grid-template-columns: 1fr;
    }

    .mutation b {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mutation,
    .can-animate:not(.is-visible) .mutation,
    .can-animate.is-visible .mutation {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
