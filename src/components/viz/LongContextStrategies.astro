---
const strategies = [
  ['Position scaling', 'Changes coordinate mapping', 'All tokens remain visible'],
  ['Sparse attention', 'Changes attention edges', 'Selected tokens remain visible'],
  ['Retrieval', 'Changes supplied context', 'Selected documents enter prompt'],
  ['Context parallelism', 'Changes device placement', 'Exact attention is distributed']
]
---

<figure class="viz" aria-labelledby="lc-title" data-lc-motion>
  <div class="viz-header">
    <figcaption id="lc-title">Long-context methods alter different layers of the system</figcaption>
    <button type="button" data-replay aria-label="Replay long-context strategy sequence"
      >Replay</button
    >
  </div>
  <div class="axis"><span>training and model</span><span>runtime and system</span></div>
  <div class="grid">
    {
      strategies.map((s, i) => (
        <section style={`--offset:${i % 2};--delay:${180 + i * 130}ms`}>
          <>
            <strong>{s[0]}</strong>
            <span>{s[1]}</span>
            <small>{s[2]}</small>
          </>
        </section>
      ))
    }
  </div>
  <p>
    A larger advertised context window does not imply uniform retrieval quality across positions.
  </p>
</figure>
<style>
  .viz {
    margin: 2em 0;
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: var(--astro-code-background);
    color: var(--text-primary);
  }
  figcaption {
    font: 600 var(--font-size-s) var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .viz-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  button {
    min-width: 4.5rem;
    min-height: 2.75rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-secondary);
    font: 0.72rem var(--mono);
    cursor: pointer;
    transition:
      transform 140ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 140ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  button:active {
    transform: scale(0.97);
  }
  button:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }
  .axis {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.45rem;
    font: 0.7rem var(--mono);
    color: var(--text-tertiary);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    margin-top: 0.7rem;
  }
  .grid section {
    display: grid;
    gap: 0.4rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--text-secondary);
    background: var(--bg);
  }
  strong {
    font: 0.8rem var(--mono);
  }
  section span {
    font-size: 0.82rem;
  }
  small {
    font: 0.7rem/1.4 var(--mono);
    color: var(--text-tertiary);
  }
  p {
    margin: 1rem 0 0;
    font: 0.76rem/1.5 var(--mono);
    color: var(--text-secondary);
  }
  .motion-ready:not(.is-running) .axis,
  .motion-ready:not(.is-running) .grid section,
  .motion-ready:not(.is-running) p {
    opacity: 0;
    transform: translateY(7px);
  }
  .motion-ready.is-running .axis {
    animation: lc-enter 300ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  .motion-ready.is-running .grid section {
    animation: lc-enter 340ms var(--delay) cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  .motion-ready.is-running p {
    animation: lc-enter 340ms 800ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  @keyframes lc-enter {
    from {
      opacity: 0;
      transform: translateY(7px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (hover: hover) and (pointer: fine) {
    button:hover {
      opacity: 0.72;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    button {
      display: none;
    }
    .motion-ready * {
      animation: none !important;
      opacity: 1 !important;
    }
  }
  @media (max-width: 560px) {
    .viz-header {
      align-items: flex-start;
    }
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lc-motion]').forEach((figure) => {
    if (figure.dataset.motionBound || matchMedia('(prefers-reduced-motion: reduce)').matches) return

    figure.dataset.motionBound = 'true'
    figure.classList.add('motion-ready')

    const play = () => {
      figure.classList.remove('is-running')
      void figure.offsetWidth
      figure.classList.add('is-running')
    }

    figure.querySelector('[data-replay]')?.addEventListener('click', play)
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return
        play()
        observer.disconnect()
      },
      { threshold: 0.35 }
    )
    observer.observe(figure)
  })
</script>
