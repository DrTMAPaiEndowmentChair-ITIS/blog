<figure class="viz proxy-viz" aria-labelledby="proxy-stack-title">
  <figcaption id="proxy-stack-title">
    <strong>Alignment supervision is a stack of proxies</strong>
    <span>Evidence at one layer does not validate every layer above it.</span>
  </figcaption>

  <div class="stack" aria-label="Alignment proxy stack">
    <section>
      <span>Target</span>
      <strong>Intended behavior</strong>
      <small>What the deployed system should do</small>
    </section>
    <div class="conversion" aria-hidden="true">
      <i>↓</i>
      <span>formalize</span>
    </div>
    <section>
      <span>Specification</span>
      <strong>Policies, principles, examples</strong>
      <small>Inspectable, but still incomplete or conflicting</small>
    </section>
    <div class="conversion" aria-hidden="true">
      <i>↓</i>
      <span>label</span>
    </div>
    <section>
      <span>Supervision</span>
      <strong>Preferences, critiques, step labels</strong>
      <small>Judgments sampled under a rubric and context</small>
    </section>
    <div class="conversion" aria-hidden="true">
      <i>↓</i>
      <span>optimize</span>
    </div>
    <section>
      <span>Objective</span>
      <strong>Reward or preference loss</strong>
      <small>The quantity the optimizer can directly improve</small>
    </section>
    <div class="conversion" aria-hidden="true">
      <i>↓</i>
      <span>generalize</span>
    </div>
    <section>
      <span>Deployment</span>
      <strong>Policy behavior in new conditions</strong>
      <small>Prompts, tools, and evaluators outside training</small>
    </section>
  </div>

  <div class="claim">
    <span>Higher training score</span>
    <i aria-hidden="true">→</i>
    <strong>better fit to the objective</strong>
    <i aria-hidden="true">≠</i>
    <strong>proof of intended behavior</strong>
  </div>
</figure>

