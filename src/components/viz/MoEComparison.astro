---
/**
 * MoE Model Comparison Table
 * Compares different MoE architectures and their specifications
 */
interface MoEModel {
  name: string;
  totalParams: string;
  activeParams: string;
  experts: string;
  activeExperts: string;
  routing: string;
  year: string;
  highlight?: boolean;
}

interface Props {
  title?: string;
}

const { title = "MoE Model Comparison" } = Astro.props;

const models: MoEModel[] = [
  {
    name: "Switch Transformer",
    totalParams: "1.6T",
    activeParams: "~100B",
    experts: "2048",
    activeExperts: "1",
    routing: "Top-1",
    year: "2021"
  },
  {
    name: "Mixtral 8x7B",
    totalParams: "46.7B",
    activeParams: "12.9B",
    experts: "8",
    activeExperts: "2",
    routing: "Top-2",
    year: "2024"
  },
  {
    name: "DeepSeek-V3",
    totalParams: "671B",
    activeParams: "37B",
    experts: "256",
    activeExperts: "8",
    routing: "Top-8 (fine-grained)",
    year: "2024",
    highlight: true
  },
  {
    name: "Qwen3-235B",
    totalParams: "235B",
    activeParams: "22B",
    experts: "128",
    activeExperts: "8",
    routing: "Top-8",
    year: "2025"
  },
  {
    name: "Qwen3-Next-80B",
    totalParams: "80B",
    activeParams: "3B",
    experts: "512",
    activeExperts: "~19",
    routing: "Ultra-sparse",
    year: "2025"
  }
];
---

<div class="moe-comparison">
  {title && <div class="comparison-title">{title}</div>}

  <div class="comparison-table">
    <div class="table-header">
      <div class="table-cell header-cell model-col">Model</div>
      <div class="table-cell header-cell">Total</div>
      <div class="table-cell header-cell">Active</div>
      <div class="table-cell header-cell">Experts</div>
      <div class="table-cell header-cell">Active/Token</div>
      <div class="table-cell header-cell routing-col">Routing</div>
    </div>

    {models.map((model) => (
      <div class={`table-row ${model.highlight ? 'highlighted' : ''}`}>
        <div class="table-cell model-col">
          <span class="model-name">{model.name}</span>
          <span class="model-year">{model.year}</span>
        </div>
        <div class="table-cell param-cell">{model.totalParams}</div>
        <div class="table-cell param-cell active-param">{model.activeParams}</div>
        <div class="table-cell">{model.experts}</div>
        <div class="table-cell">{model.activeExperts}</div>
        <div class="table-cell routing-col routing-cell">{model.routing}</div>
      </div>
    ))}
  </div>

  <div class="comparison-footer">
    <div class="footer-note">
      <span class="note-label">Active params</span>
      <span class="note-text">Parameters computed per token forward pass</span>
    </div>
    <div class="footer-note">
      <span class="note-label">Efficiency</span>
      <span class="note-text">Higher total/active ratio = more sparse</span>
    </div>
  </div>
</div>

<style>
  .moe-comparison {
    margin: 2em 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .comparison-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .comparison-table {
    display: grid;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    overflow: hidden;
    min-width: 600px;
  }

  .table-header,
  .table-row {
    display: grid;
    grid-template-columns: 160px 70px 70px 70px 90px 1fr;
  }

  .table-cell {
    padding: 0.625rem 0.75rem;
    background: var(--bg);
    font-family: var(--mono);
    font-size: 0.8125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s ease-out;
  }

  .header-cell {
    background: var(--astro-code-background);
    font-weight: var(--font-weight-bold);
    color: var(--text-secondary);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .model-col {
    justify-content: flex-start;
  }

  .model-col.header-cell {
    justify-content: flex-start;
  }

  .model-name {
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .model-year {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    margin-left: 0.5rem;
  }

  .param-cell {
    font-weight: var(--font-weight-bold);
  }

  .active-param {
    color: var(--text-secondary);
  }

  .routing-col {
    text-align: left;
    justify-content: flex-start;
  }

  .routing-cell {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .table-row:hover .table-cell {
    background: var(--code-bg);
  }

  .table-row.highlighted .table-cell {
    background: var(--selection);
  }

  .table-row.highlighted:hover .table-cell {
    background: var(--selection);
  }

  .table-row.highlighted .model-name {
    color: var(--text-primary);
  }

  /* Footer */
  .comparison-footer {
    display: flex;
    gap: 2rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .footer-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .note-label {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .note-text {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  @media (max-width: 700px) {
    .table-header,
    .table-row {
      grid-template-columns: 140px 60px 60px 60px 80px 1fr;
    }

    .table-cell {
      padding: 0.5rem;
      font-size: 0.875rem;
    }

    .comparison-footer {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
