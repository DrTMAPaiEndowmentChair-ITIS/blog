---
/**
 * Audio Processing Pipeline Visualization
 * Shows the flow from raw audio through encoding to text output
 * Designed for speech-to-text (ASR) architecture diagrams
 */
interface Stage {
  id: string;
  label: string;
  sublabel?: string;
  icon: 'waveform' | 'spectrogram' | 'conv' | 'transformer' | 'decoder' | 'text' | 'embedding' | 'attention';
  details?: string[];
  color?: 'accent' | 'highlight' | 'muted';
}

interface Props {
  stages: Stage[];
  title?: string;
  subtitle?: string;
  animated?: boolean;
}

const { stages, title, subtitle, animated = true } = Astro.props;
---

<div class="audio-pipeline" data-animated={animated}>
  {title && (
    <div class="pipeline-header">
      <div class="pipeline-title">{title}</div>
      {subtitle && <div class="pipeline-subtitle">{subtitle}</div>}
    </div>
  )}

  <div class="pipeline-container">
    {animated && (
      <button class="play-btn" aria-label="Play animation">
        <svg class="play-icon" width="10" height="10" viewBox="0 0 16 16" fill="currentColor">
          <path d="M4 2.5v11l9-5.5-9-5.5z"/>
        </svg>
        <svg class="pause-icon" width="10" height="10" viewBox="0 0 16 16" fill="currentColor">
          <rect x="3" y="2" width="4" height="12"/><rect x="9" y="2" width="4" height="12"/>
        </svg>
      </button>
    )}

    <div class="pipeline-track">
      {stages.map((stage, index) => (
        <>
          <div
            class={`pipeline-stage ${stage.color || 'muted'}`}
            data-stage-id={stage.id}
            data-stage-index={index}
          >
            <div class="stage-icon">
              {stage.icon === 'waveform' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 12h1M5 9v6M8 6v12M11 8v8M14 5v14M17 8v8M20 10v4M23 12h0" stroke-linecap="round"/>
                </svg>
              )}
              {stage.icon === 'spectrogram' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="3" width="18" height="18" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <rect x="5" y="14" width="2" height="4" fill="currentColor" opacity="0.4"/>
                  <rect x="8" y="11" width="2" height="7" fill="currentColor" opacity="0.6"/>
                  <rect x="11" y="7" width="2" height="11" fill="currentColor" opacity="0.8"/>
                  <rect x="14" y="10" width="2" height="8" fill="currentColor" opacity="0.6"/>
                  <rect x="17" y="13" width="2" height="5" fill="currentColor" opacity="0.4"/>
                </svg>
              )}
              {stage.icon === 'conv' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="7" width="5" height="10" rx="1"/>
                  <rect x="10" y="5" width="5" height="14" rx="1"/>
                  <rect x="17" y="3" width="4" height="18" rx="1"/>
                </svg>
              )}
              {stage.icon === 'transformer' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="6" y="3" width="12" height="4" rx="1"/>
                  <rect x="6" y="10" width="12" height="4" rx="1"/>
                  <rect x="6" y="17" width="12" height="4" rx="1"/>
                  <path d="M12 7v3M12 14v3" stroke-linecap="round"/>
                </svg>
              )}
              {stage.icon === 'decoder' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="4" y="4" width="16" height="16" rx="2"/>
                  <path d="M8 9h8M8 12h8M8 15h4"/>
                </svg>
              )}
              {stage.icon === 'text' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M6 6h12M12 6v12M9 18h6"/>
                </svg>
              )}
              {stage.icon === 'embedding' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="6" cy="6" r="2"/>
                  <circle cx="18" cy="6" r="2"/>
                  <circle cx="6" cy="18" r="2"/>
                  <circle cx="18" cy="18" r="2"/>
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M8 8l2 2M14 8l-2 2M8 16l2-2M14 16l-2-2"/>
                </svg>
              )}
              {stage.icon === 'attention' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="8"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
                </svg>
              )}
            </div>
            <div class="stage-content">
              <span class="stage-label">{stage.label}</span>
              {stage.sublabel && <span class="stage-sublabel">{stage.sublabel}</span>}
            </div>
          </div>
          {index < stages.length - 1 && (
            <div class="pipeline-connector">
              <div class="connector-line"></div>
              {animated && <div class="data-pulse" data-stage={index}></div>}
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</div>

<script>
  function initAudioPipeline() {
    document.querySelectorAll('.audio-pipeline[data-animated="true"]').forEach((container) => {
      const playBtn = container.querySelector('.play-btn');
      const pulses = container.querySelectorAll('.data-pulse');
      const stages = container.querySelectorAll('.pipeline-stage');

      let isPlaying = false;
      let animationTimeout: ReturnType<typeof setTimeout>;
      let currentStage = -1;
      const speed = 600;

      const resetAnimation = () => {
        pulses.forEach((p) => p.classList.remove('active'));
        stages.forEach((s) => s.classList.remove('active'));
        currentStage = -1;
      };

      const animate = () => {
        if (!isPlaying) return;

        currentStage++;

        if (currentStage >= stages.length) {
          resetAnimation();
          animationTimeout = setTimeout(animate, speed);
          return;
        }

        stages[currentStage].classList.add('active');

        if (currentStage > 0) {
          pulses[currentStage - 1].classList.add('active');
        }

        if (currentStage > 1) {
          stages[currentStage - 2].classList.remove('active');
          pulses[currentStage - 2]?.classList.remove('active');
        }

        animationTimeout = setTimeout(animate, speed);
      };

      const togglePlay = () => {
        isPlaying = !isPlaying;
        container.classList.toggle('playing', isPlaying);

        if (isPlaying) {
          resetAnimation();
          animate();
        } else {
          clearTimeout(animationTimeout);
          resetAnimation();
        }
      };

      const newPlayBtn = playBtn?.cloneNode(true);
      if (playBtn && newPlayBtn) {
        playBtn.parentNode?.replaceChild(newPlayBtn, playBtn);
        newPlayBtn.addEventListener('click', togglePlay);
      }
    });
  }

  initAudioPipeline();
  document.addEventListener('astro:after-swap', initAudioPipeline);
</script>

<style>
  .audio-pipeline {
    margin: 2em 0;
    padding: 1rem;
    background: var(--astro-code-background);
    border: 1px solid var(--border);
    border-radius: 0;
  }

  .pipeline-header {
    margin-bottom: 1rem;
  }

  .pipeline-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pipeline-subtitle {
    font-size: 0.55rem;
    color: var(--text-tertiary);
    margin-top: 0.125rem;
  }

  .pipeline-container {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .play-btn {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-tertiary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease-out;
    flex-shrink: 0;
  }

  .play-btn:hover {
    border-color: var(--text-secondary);
    color: var(--text-secondary);
  }

  .play-btn .pause-icon {
    display: none;
  }

  .audio-pipeline.playing .play-btn {
    background: var(--text-secondary);
    border-color: var(--text-secondary);
    color: var(--bg);
  }

  .audio-pipeline.playing .play-btn .play-icon {
    display: none;
  }

  .audio-pipeline.playing .play-btn .pause-icon {
    display: block;
  }

  .pipeline-track {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .pipeline-stage {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0;
    transition: all 0.15s ease-out;
  }

  .pipeline-stage.accent {
    border-left: 2px solid var(--text-secondary);
  }

  .pipeline-stage.highlight {
    border-left: 2px solid var(--text-tertiary);
  }

  .pipeline-stage.active {
    background: var(--selection);
    border-color: var(--text-secondary);
  }

  .stage-icon {
    width: 20px;
    height: 20px;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .pipeline-stage.accent .stage-icon {
    color: var(--text-secondary);
  }

  .pipeline-stage.active .stage-icon {
    color: var(--text-secondary);
  }

  .stage-icon svg {
    width: 100%;
    height: 100%;
  }

  .stage-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .stage-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--text-primary);
    font-weight: var(--font-weight-bold);
  }

  .stage-sublabel {
    font-size: 0.5rem;
    color: var(--text-tertiary);
  }

  .pipeline-connector {
    display: flex;
    align-items: center;
    padding-left: 0.875rem;
    height: 12px;
    position: relative;
  }

  .connector-line {
    width: 1px;
    height: 100%;
    background: var(--border);
  }

  .data-pulse {
    position: absolute;
    left: 0.625rem;
    top: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-secondary);
    opacity: 0;
    transition: top 0.4s ease-out, opacity 0.15s ease-out;
  }

  .data-pulse.active {
    opacity: 1;
    top: calc(100% - 5px);
  }

  @media (min-width: 500px) {
    .pipeline-track {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.375rem;
    }

    .pipeline-stage {
      flex: 1 1 auto;
      min-width: 100px;
      max-width: 150px;
      flex-direction: column;
      text-align: center;
      padding: 0.625rem 0.5rem;
    }

    .pipeline-stage.accent,
    .pipeline-stage.highlight {
      border-left: 1px solid var(--border);
      border-top: 2px solid var(--text-secondary);
    }

    .pipeline-stage.highlight {
      border-top-color: var(--text-tertiary);
    }

    .stage-content {
      align-items: center;
    }

    .pipeline-connector {
      display: none;
    }
  }
</style>
