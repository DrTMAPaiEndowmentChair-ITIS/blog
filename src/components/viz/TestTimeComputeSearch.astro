<figure class="viz search-viz" aria-labelledby="test-time-title" data-search-viz>
  <div class="viz-header">
    <figcaption id="test-time-title">
      A verifier should spend the next unit of compute on the best partial path
    </figcaption>
    <button type="button" data-replay aria-label="Replay verifier-guided search">Replay</button>
  </div>

  <div class="search-map">
    <section class="prompt" data-step>
      <span>Prompt</span>
      <strong>Initial reasoning state</strong>
    </section>

    <div class="connector" data-step aria-hidden="true">↓ generate diverse candidates</div>

    <div class="candidates" data-step>
      <section>
        <span>Candidate A</span>
        <strong>Dead end</strong>
        <small>low process value</small>
      </section>
      <section class="chosen">
        <span>Candidate B</span>
        <strong>Promising prefix</strong>
        <small>uncertain, worth expanding</small>
      </section>
      <section>
        <span>Candidate C</span>
        <strong>Duplicate path</strong>
        <small>adds little diversity</small>
      </section>
      <section>
        <span>Candidate D</span>
        <strong>Complete path</strong>
        <small>high outcome value</small>
      </section>
    </div>

    <div class="verifier-row" data-step>
      <div>
        <span>Process verifier</span>
        <strong>Prune A and C</strong>
      </div>
      <div>
        <span>Budget allocator</span>
        <strong>Expand B, retain D</strong>
      </div>
    </div>

    <div class="connector selected-connector" data-step aria-hidden="true">
      ↓ spend compute where expected value is highest
    </div>

    <div class="expansion" data-step>
      <section>
        <span>B.1</span>
        <strong>Fails verification</strong>
      </section>
      <section class="chosen">
        <span>B.2</span>
        <strong>Verified completion</strong>
      </section>
      <section class="answer">
        <span>Stop rule</span>
        <strong>Select B.2</strong>
        <small>adequate verifier margin</small>
      </section>
    </div>
  </div>

  <p class="principle" data-step>
    More tokens help only when generation explores useful alternatives, verification ranks them, and
    a stopping rule prevents overthinking.
  </p>
</figure>

<style>
  .viz {
    container-type: inline-size;
    margin: 2em 0;
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: var(--astro-code-background);
    color: var(--text-primary);
  }
  .viz-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  figcaption {
    max-width: 34rem;
    font: 600 var(--font-size-s) var(--mono);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  button {
    flex: none;
    min-width: 4.5rem;
    min-height: 2.75rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-secondary);
    font: 0.72rem var(--mono);
    cursor: pointer;
    transition:
      transform 140ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 140ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  button:active {
    transform: scale(0.97);
  }
  button:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }
  .search-map {
    display: grid;
    gap: 0.65rem;
  }
  section {
    min-width: 0;
  }
  .prompt {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0.9rem;
    border-left: 2px solid var(--text-secondary);
    background: var(--bg);
  }
  span,
  small,
  .connector,
  .principle {
    font: 0.68rem/1.45 var(--mono);
  }
  span {
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  strong {
    font: 600 0.8rem/1.35 var(--sans);
  }
  small {
    color: var(--text-secondary);
  }
  .connector {
    padding-left: 0.85rem;
    color: var(--text-tertiary);
  }
  .candidates {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid var(--border);
  }
  .candidates section {
    display: grid;
    align-content: start;
    gap: 0.45rem;
    padding: 0.85rem;
    border-right: 1px solid var(--border);
    background: var(--bg);
  }
  .candidates section:last-child {
    border-right: 0;
  }
  .chosen {
    box-shadow: inset 0 2px 0 var(--text-primary);
  }
  .verifier-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem;
  }
  .verifier-row div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0.85rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .selected-connector {
    color: var(--text-secondary);
  }
  .expansion {
    display: grid;
    grid-template-columns: 0.9fr 0.9fr 1.2fr;
    gap: 0.65rem;
  }
  .expansion section {
    display: grid;
    gap: 0.4rem;
    padding: 0.8rem 0.85rem;
    border: 1px solid var(--border);
    background: var(--bg);
  }
  .expansion .answer {
    border-color: var(--text-secondary);
  }
  .principle {
    margin: 0.85rem 0 0;
    padding-top: 0.85rem;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
  }
  @media (hover: hover) and (pointer: fine) {
    button:hover {
      opacity: 0.72;
    }
  }
  @container (max-width: 560px) {
    .candidates {
      grid-template-columns: 1fr 1fr;
    }
    .candidates section:nth-child(2) {
      border-right: 0;
    }
    .candidates section:nth-child(-n + 2) {
      border-bottom: 1px solid var(--border);
    }
  }
  @container (max-width: 430px) {
    .viz-header {
      display: grid;
    }
    button {
      justify-self: start;
    }
    .verifier-row {
      grid-template-columns: 1fr;
    }
    .verifier-row div {
      display: grid;
      gap: 0.35rem;
    }
    .expansion {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    button {
      display: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-search-viz]').forEach((figure) => {
    if (figure.dataset.motionBound) return
    figure.dataset.motionBound = 'true'

    let animations: Animation[] = []
    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches
    const steps = Array.from(figure.querySelectorAll<HTMLElement>('[data-step]'))

    const play = () => {
      animations.forEach((animation) => animation.cancel())
      animations = steps.map((step, index) =>
        step.animate(
          reduceMotion
            ? [{ opacity: 0.55 }, { opacity: 1 }]
            : [
                { opacity: 0.24, transform: 'translateY(7px)' },
                { opacity: 1, transform: 'translateY(0)' }
              ],
          {
            duration: reduceMotion ? 160 : 280,
            delay: index * (reduceMotion ? 55 : 210),
            fill: 'both',
            easing: 'cubic-bezier(0.23, 1, 0.32, 1)'
          }
        )
      )
    }

    figure.querySelector('[data-replay]')?.addEventListener('click', play)
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return
        play()
        observer.disconnect()
      },
      { threshold: 0.3 }
    )
    observer.observe(figure)
  })
</script>
