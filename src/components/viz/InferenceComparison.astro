---
/**
 * Comparison visualization for LLM inference engines
 * Shows TensorRT-LLM vs vLLM vs TGI characteristics
 */
interface Engine {
  name: string;
  highlight?: boolean;
  metrics: {
    throughput: string;
    latency: string;
    setupTime: string;
    bestFor: string;
  };
}

interface Props {
  title?: string;
}

const { title = "LLM Inference Engine Comparison" } = Astro.props;

const engines: Engine[] = [
  {
    name: "TensorRT-LLM",
    highlight: true,
    metrics: {
      throughput: "700 tok/s @ 100 users",
      latency: "35-50ms TTFT",
      setupTime: "1-2 weeks",
      bestFor: "Peak performance"
    }
  },
  {
    name: "vLLM",
    metrics: {
      throughput: "600-650 tok/s @ 100 users",
      latency: "50-80ms TTFT",
      setupTime: "1-2 days",
      bestFor: "High concurrency"
    }
  },
  {
    name: "TGI v3",
    metrics: {
      throughput: "600-650 tok/s @ 100 users",
      latency: "50-70ms TTFT",
      setupTime: "1-2 days",
      bestFor: "Long contexts"
    }
  }
];

const metricLabels: Record<string, string> = {
  throughput: "Throughput (A100 80GB)",
  latency: "Time to First Token",
  setupTime: "Setup Complexity",
  bestFor: "Best Use Case"
};
---

<div class="inference-compare">
  <div class="compare-title">{title}</div>

  <div class="compare-grid">
    <div class="grid-header">
      <div class="grid-cell header-cell metric-label"></div>
      {engines.map((engine) => (
        <div class={`grid-cell header-cell engine-name ${engine.highlight ? 'highlighted' : ''}`}>
          {engine.name}
        </div>
      ))}
    </div>

    {Object.keys(metricLabels).map((key) => (
      <div class="grid-row" data-metric={key}>
        <div class="grid-cell metric-label">{metricLabels[key]}</div>
        {engines.map((engine) => (
          <div class={`grid-cell metric-value ${engine.highlight ? 'highlighted' : ''}`}>
            {engine.metrics[key as keyof typeof engine.metrics]}
          </div>
        ))}
      </div>
    ))}
  </div>

  <div class="compare-note">
    Benchmarks from BentoML testing Llama 3 70B Q4. Results vary by model and hardware.
  </div>
</div>

<style>
  .inference-compare {
    margin: 2em 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .compare-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .compare-grid {
    display: grid;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 0;
    overflow: hidden;
    min-width: fit-content;
  }

  .grid-header,
  .grid-row {
    display: grid;
    grid-template-columns: 160px repeat(3, minmax(140px, 1fr));
  }

  .grid-cell {
    padding: 0.75rem 1rem;
    background: var(--bg);
    font-size: var(--font-size-s);
    transition: background 0.1s ease-out;
  }

  .header-cell {
    background: var(--astro-code-background);
    font-weight: var(--font-weight-bold);
  }

  .metric-label {
    color: var(--text-secondary);
    font-family: var(--mono);
    font-size: 0.875rem;
  }

  .metric-value {
    font-family: var(--mono);
    text-align: center;
    font-size: 0.875rem;
  }

  .engine-name {
    text-align: center;
  }

  .highlighted {
    background: var(--selection) !important;
  }

  .highlighted.header-cell {
    color: var(--text-secondary);
  }

  .grid-row:hover .grid-cell {
    background: var(--code-bg);
  }

  .grid-row:hover .highlighted {
    background: var(--selection) !important;
  }

  .compare-note {
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .grid-header,
    .grid-row {
      grid-template-columns: 120px repeat(3, minmax(100px, 1fr));
    }

    .grid-cell {
      padding: 0.5rem 0.625rem;
      font-size: 0.8125rem;
    }

    .metric-value {
      font-size: 0.875rem;
    }
  }
</style>
