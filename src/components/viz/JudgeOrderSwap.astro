<figure class="judge-viz" aria-labelledby="judge-title">
  <figcaption id="judge-title">Order swapping exposes a position-sensitive judge</figcaption>
  <div class="passes">
    <section class="pass pass-one">
      <span class="label">pass one</span>
      <div><b>left: A</b><small>candidate answer</small></div>
      <i aria-hidden="true">vs</i>
      <div><b>right: B</b><small>candidate answer</small></div>
      <strong class="result">judge: left wins</strong>
    </section>
    <section class="pass pass-two">
      <span class="label">order swapped</span>
      <div><b>left: B</b><small>same answer B</small></div>
      <i aria-hidden="true">vs</i>
      <div><b>right: A</b><small>same answer A</small></div>
      <strong class="result">judge: left wins</strong>
    </section>
  </div>
  <div class="gate">
    <span>preferred answer changed when only position changed</span>
    <b>route to disagreement review</b>
  </div>
  <p>
    Candidate identity and content stay fixed. A flipped preference is evidence that the judge
    cannot support an automatic decision for this case.
  </p>
</figure>

<script>
  function initializeJudgeSwap() {
    if (!('IntersectionObserver' in window)) return
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return

    document.querySelectorAll<HTMLElement>('.judge-viz').forEach((figure) => {
      if (figure.dataset.motionReady) return
      figure.dataset.motionReady = 'true'
      figure.classList.add('can-animate')
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry?.isIntersecting) return
          figure.classList.add('is-visible')
          observer.disconnect()
        },
        { threshold: 0.2 }
      )
      observer.observe(figure)
    })
  }

  initializeJudgeSwap()
  document.addEventListener('astro:page-load', initializeJudgeSwap)
</script>

<style>
  .judge-viz {
    margin: 2rem 0;
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--code-bg);
  }

  figcaption {
    margin-bottom: 0.75rem;
    font: 600 0.8125rem/1.45 var(--mono);
  }

  .passes {
    display: grid;
    gap: 0.5rem;
  }

  .pass {
    display: grid;
    grid-template-columns: 5.5rem 1fr 1.5rem 1fr 7.5rem;
    gap: 0.4rem;
    align-items: center;
    padding: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    opacity: 1;
    transform: none;
  }

  .can-animate:not(.is-visible) .pass {
    opacity: 0;
    transform: translateX(-0.45rem);
  }

  .can-animate.is-visible .pass {
    animation: judge-pass 280ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }

  .pass-two {
    animation-delay: 480ms;
  }

  .label {
    color: var(--text-secondary);
    font: 0.6875rem/1.35 var(--mono);
  }

  .pass div {
    min-width: 0;
    padding: 0.45rem;
    border: 1px solid var(--border);
  }

  .pass b,
  .pass small {
    display: block;
  }

  .pass b {
    font: 600 0.6875rem/1.3 var(--mono);
  }

  .pass small {
    margin-top: 0.15rem;
    color: var(--text-tertiary);
    font-size: 0.625rem;
    line-height: 1.3;
  }

  .pass i {
    color: var(--text-tertiary);
    font: 0.625rem/1 var(--mono);
    text-align: center;
  }

  .result {
    font: 600 0.6875rem/1.35 var(--mono);
    text-align: center;
  }

  .gate {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.65rem;
    align-items: center;
    margin-top: 0.5rem;
    padding: 0.65rem;
    border: 1px dashed var(--text-secondary);
    background: var(--bg);
    opacity: 1;
    transform: none;
  }

  .can-animate:not(.is-visible) .gate {
    opacity: 0;
    transform: translateY(0.35rem);
  }

  .can-animate.is-visible .gate {
    animation: judge-pass 260ms cubic-bezier(0.23, 1, 0.32, 1) 900ms both;
  }

  .gate span {
    color: var(--text-secondary);
    font-size: 0.6875rem;
    line-height: 1.4;
  }

  .gate b {
    font: 600 0.6875rem/1.35 var(--mono);
  }

  p {
    margin: 0.75rem 0 0;
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  @keyframes judge-pass {
    to {
      opacity: 1;
      transform: translate(0);
    }
  }

  @media (max-width: 620px) {
    .pass {
      grid-template-columns: 1fr 1.25rem 1fr;
    }

    .label,
    .result {
      grid-column: 1 / -1;
      text-align: left;
    }

    .gate {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pass,
    .gate,
    .can-animate:not(.is-visible) .pass,
    .can-animate.is-visible .pass,
    .can-animate:not(.is-visible) .gate,
    .can-animate.is-visible .gate {
      transform: none;
      animation: none;
    }

    .pass,
    .can-animate:not(.is-visible) .pass,
    .can-animate.is-visible .pass {
      opacity: 1;
    }

    .gate,
    .can-animate:not(.is-visible) .gate,
    .can-animate.is-visible .gate {
      opacity: 1;
    }
  }
</style>
