---
/**
 * Apple ML Stack visualization
 * Shows the layered architecture from Apps down to Hardware
 * with framework integrations on the side
 */
interface Layer {
  name: string;
  type: string;
  description?: string;
  color?: 'accent' | 'highlight' | 'muted';
}

interface Framework {
  name: string;
  connectsTo: string[];
  color?: 'accent' | 'highlight' | 'muted';
}

interface Props {
  title?: string;
  showFrameworks?: boolean;
}

const { title = "Apple ML Stack Architecture", showFrameworks = true } = Astro.props;

const layers: Layer[] = [
  { name: "Applications", type: "Apps & Services", description: "iOS, macOS, watchOS, visionOS apps", color: "muted" },
  { name: "CoreML", type: "Deployment Framework", description: "Hardware-agnostic model deployment", color: "accent" },
  { name: "MPSGraph", type: "Compute Graphs", description: "Graph-based GPU execution", color: "highlight" },
  { name: "MPS", type: "GPU Primitives", description: "Metal Performance Shaders", color: "highlight" },
  { name: "Metal", type: "GPU API", description: "Low-level GPU programming", color: "muted" },
  { name: "Hardware", type: "GPU / Neural Engine / AMX", description: "Apple Silicon accelerators", color: "accent" }
];

const frameworks: Framework[] = [
  { name: "PyTorch MPS", connectsTo: ["MPSGraph", "MPS"], color: "highlight" },
  { name: "MLX", connectsTo: ["Metal", "MPS"], color: "accent" },
  { name: "TensorFlow Metal", connectsTo: ["Metal"], color: "muted" },
  { name: "BNNS / Accelerate", connectsTo: ["Hardware"], color: "muted" }
];
---

<div class="apple-ml-stack">
  <div class="stack-title">{title}</div>

  <div class="stack-layout">
    <div class="main-stack">
      {layers.map((layer, index) => (
        <div class={`stack-layer ${layer.color || 'muted'}`} data-layer={layer.name}>
          <div class="layer-content">
            <div class="layer-header">
              <span class="layer-name">{layer.name}</span>
              <span class="layer-type">{layer.type}</span>
            </div>
            {layer.description && (
              <div class="layer-description">{layer.description}</div>
            )}
          </div>
          {index < layers.length - 1 && (
            <div class="layer-connector">
              <svg width="12" height="24" viewBox="0 0 12 24" fill="none">
                <path d="M6 0V24M6 24L2 20M6 24L10 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    {showFrameworks && (
      <div class="frameworks-panel">
        <div class="panel-title">Framework Integration</div>
        <div class="frameworks-list">
          {frameworks.map((fw) => (
            <div
              class={`framework-item ${fw.color || 'muted'}`}
              data-framework={fw.name}
              data-connects={fw.connectsTo.join(',')}
            >
              <span class="framework-name">{fw.name}</span>
              <div class="connect-indicator">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M2 8H14M14 8L10 4M14 8L10 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="connect-targets">
                {fw.connectsTo.map((target) => (
                  <span class="connect-target">{target}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <div class="stack-legend">
    <div class="legend-item">
      <span class="legend-dot accent"></span>
      <span>Primary ML APIs</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot highlight"></span>
      <span>GPU Compute Layer</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot muted"></span>
      <span>Foundation / Hardware</span>
    </div>
  </div>
</div>

<script>
  function initAppleMLStack() {
    document.querySelectorAll('.apple-ml-stack').forEach((container) => {
      const layers = container.querySelectorAll('.stack-layer');
      const frameworks = container.querySelectorAll('.framework-item');

      // Highlight connected layers when hovering frameworks
      frameworks.forEach((fw) => {
        const connects = (fw as HTMLElement).dataset.connects?.split(',') || [];

        fw.addEventListener('mouseenter', () => {
          fw.classList.add('active');
          layers.forEach((layer) => {
            const layerName = (layer as HTMLElement).dataset.layer;
            if (connects.includes(layerName || '')) {
              layer.classList.add('connected');
            }
          });
        });

        fw.addEventListener('mouseleave', () => {
          fw.classList.remove('active');
          layers.forEach((layer) => layer.classList.remove('connected'));
        });
      });

      // Highlight framework connections when hovering layers
      layers.forEach((layer) => {
        const layerName = (layer as HTMLElement).dataset.layer;

        layer.addEventListener('mouseenter', () => {
          layer.classList.add('active');
          frameworks.forEach((fw) => {
            const connects = (fw as HTMLElement).dataset.connects?.split(',') || [];
            if (connects.includes(layerName || '')) {
              fw.classList.add('connected');
            }
          });
        });

        layer.addEventListener('mouseleave', () => {
          layer.classList.remove('active');
          frameworks.forEach((fw) => fw.classList.remove('connected'));
        });
      });
    });
  }

  initAppleMLStack();
  document.addEventListener('astro:after-swap', initAppleMLStack);
</script>

<style>
  .apple-ml-stack {
    margin: 2em 0;
    padding: 1.5rem;
    background: var(--astro-code-background);
    border: 1px solid var(--border);
    border-radius: 0;
  }

  .stack-title {
    font-family: var(--mono);
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stack-layout {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
  }

  .main-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stack-layer {
    width: 100%;
    max-width: 320px;
    position: relative;
    transition: all 0.2s ease-out;
  }

  .stack-layer:hover,
  .stack-layer.active {
    transform: translateX(4px);
  }

  .stack-layer.connected {
    transform: translateX(8px);
  }

  .layer-content {
    padding: 0.875rem 1.25rem;
    border-radius: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    transition: all 0.2s ease-out;
  }

  .stack-layer.accent .layer-content {
    border-color: var(--text-secondary);
    background: var(--selection);
  }

  .stack-layer.highlight .layer-content {
    border-color: var(--text-tertiary);
    background: var(--code-bg);
  }

  .stack-layer.connected .layer-content {
    box-shadow: 0 0 0 2px var(--text-secondary);
  }

  .layer-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .layer-name {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .layer-type {
    font-family: var(--mono);
    font-size: 0.55rem;
    padding: 0.1rem 0.375rem;
    background: var(--code-bg);
    border-radius: 0;
    color: var(--text-tertiary);
  }

  .stack-layer.accent .layer-type {
    background: rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
  }

  .stack-layer.highlight .layer-type {
    background: rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
  }

  .layer-description {
    font-size: 0.6rem;
    color: var(--text-tertiary);
    margin-top: 0.25rem;
  }

  .layer-connector {
    display: flex;
    justify-content: center;
    padding: 0.375rem 0;
    color: var(--border);
  }

  /* Frameworks Panel */
  .frameworks-panel {
    min-width: 200px;
    padding: 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0;
  }

  .panel-title {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.75rem;
  }

  .frameworks-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .framework-item {
    padding: 0.5rem 0.625rem;
    border-radius: 0;
    background: var(--code-bg);
    border: 1px solid var(--border);
    cursor: default;
    transition: all 0.2s ease-out;
  }

  .framework-item:hover,
  .framework-item.active {
    transform: translateX(-4px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  html.dark .framework-item:hover,
  html.dark .framework-item.active {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .framework-item.connected {
    border-color: var(--text-secondary);
    background: var(--selection);
  }

  .framework-item.accent {
    border-left: 3px solid var(--text-secondary);
  }

  .framework-item.highlight {
    border-left: 3px solid var(--text-tertiary);
  }

  .framework-name {
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .connect-indicator {
    display: none;
  }

  .connect-targets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .connect-target {
    font-size: 0.5rem;
    padding: 0.1rem 0.25rem;
    background: var(--bg);
    border-radius: 0;
    color: var(--text-tertiary);
    font-family: var(--mono);
  }

  /* Legend */
  .stack-legend {
    display: flex;
    gap: 1rem;
    margin-top: 1.25rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .legend-item span:last-child {
    font-size: 0.5rem;
    color: var(--text-tertiary);
    font-family: var(--mono);
  }

  .legend-dot {
    width: 6px;
    height: 6px;
    border-radius: 0;
    flex-shrink: 0;
  }

  .legend-dot.accent {
    background: var(--text-secondary);
  }

  .legend-dot.highlight {
    background: var(--text-tertiary);
  }

  .legend-dot.muted {
    background: var(--border);
  }

  /* Responsive */
  @media (max-width: 700px) {
    .stack-layout {
      grid-template-columns: 1fr;
    }

    .frameworks-panel {
      order: -1;
    }

    .frameworks-list {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .framework-item {
      flex: 1 1 auto;
      min-width: 140px;
    }

    .framework-item:hover,
    .framework-item.active {
      transform: translateY(-2px);
    }
  }
</style>
