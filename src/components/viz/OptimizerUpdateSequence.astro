---
const steps = [
  ['unscale', 'recover gradient magnitude'],
  ['finite check', 'stop on invalid values'],
  ['clip', 'bound the chosen norm'],
  ['statistics', 'update moments or factors'],
  ['precondition', 'construct the update'],
  ['weight decay', 'apply decoupled decay'],
  ['parameter', 'commit the new value']
]
---

<figure class="update-viz" aria-labelledby="update-title">
  <figcaption id="update-title">Optimizer operations are ordered, not interchangeable</figcaption>
  <div class="sequence">
    <div class="rail" aria-hidden="true"><i></i></div>
    <ol>
      {
        steps.map(([name, detail], index) => (
          <li style={`--delay: ${index * 120}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{name}</strong>
            <small>{detail}</small>
          </li>
        ))
      }
    </ol>
  </div>
  <p>
    Moving clipping after preconditioning changes which quantity is bounded. Checkpoints must
    preserve every stateful stage.
  </p>
</figure>

<script>
  function initializeOptimizerSequence() {
    if (!('IntersectionObserver' in window)) return
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return

    document.querySelectorAll<HTMLElement>('.update-viz').forEach((figure) => {
      if (figure.dataset.motionReady) return
      figure.dataset.motionReady = 'true'
      figure.classList.add('can-animate')
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry?.isIntersecting) return
          figure.classList.add('is-visible')
          observer.disconnect()
        },
        { threshold: 0.2 }
      )
      observer.observe(figure)
    })
  }

  initializeOptimizerSequence()
  document.addEventListener('astro:page-load', initializeOptimizerSequence)
</script>

<style>
  .update-viz {
    margin: 2rem 0;
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--code-bg);
  }

  figcaption {
    margin-bottom: 0.75rem;
    font: 600 0.8125rem/1.45 var(--mono);
  }

  .sequence {
    position: relative;
    padding-left: 1.2rem;
  }

  .rail {
    position: absolute;
    top: 1rem;
    bottom: 1rem;
    left: 0.25rem;
    width: 1px;
    background: var(--border);
  }

  .rail i {
    position: absolute;
    top: -0.2rem;
    left: -0.22rem;
    width: 0.45rem;
    height: 0.45rem;
    border: 1px solid var(--text-secondary);
    border-radius: 50%;
    background: var(--bg);
  }

  .can-animate.is-visible .rail i {
    animation: optimizer-cursor 1.2s steps(6, end) 100ms both;
  }

  ol {
    display: grid;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 2.2rem 6.5rem 1fr;
    gap: 0.5rem;
    align-items: center;
    min-height: 2.3rem;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    opacity: 1;
    transform: none;
  }

  .can-animate:not(.is-visible) li {
    opacity: 0;
    transform: translateX(-0.3rem);
  }

  .can-animate.is-visible li {
    animation: optimizer-step 220ms cubic-bezier(0.23, 1, 0.32, 1) var(--delay) both;
  }

  li > span {
    color: var(--text-tertiary);
    font: 0.6875rem/1 var(--mono);
  }

  li strong {
    font: 600 0.75rem/1.3 var(--mono);
  }

  li small {
    color: var(--text-secondary);
    font: 0.75rem/1.4 var(--sans);
  }

  p {
    margin: 0.75rem 0 0;
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  @keyframes optimizer-step {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes optimizer-cursor {
    to {
      transform: translateY(16.5rem);
    }
  }

  @media (max-width: 500px) {
    li {
      grid-template-columns: 1.75rem 1fr;
    }

    li small {
      grid-column: 2;
    }

    @keyframes optimizer-cursor {
      to {
        transform: translateY(23rem);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail i,
    .can-animate.is-visible .rail i {
      top: auto;
      bottom: -0.2rem;
      animation: none;
    }

    li,
    .can-animate:not(.is-visible) li,
    .can-animate.is-visible li {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
